{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci",
  "buildCommand": "astro build",
  "framework": "astro",
  "comment": "embarques-antigravity → asli.cl/embarques (proxy via web2). Deploy: 2026-03-30",
  "redirects": [
    {
      "source": "/favicon.ico",
      "destination": "/embarques/logoasli.png",
      "permanent": false
    },
    {
      "source": "/embarques/favicon.ico",
      "destination": "/embarques/logoasli.png",
      "permanent": false
    }
  ]
}
