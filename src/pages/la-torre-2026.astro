---
import { withBase } from "@/lib/basePath";
const SUPA_URL = import.meta.env.PUBLIC_SUPABASE_URL;
const SUPA_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/png" href={withBase("/img/logo-la-torre-stone-fruit.png")} />
    <title>LA TORRE 2026</title>
    <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
    <script is:inline define:vars={{ SUPA_URL, SUPA_KEY }}>
      window._supaUrl = SUPA_URL;
      window._supaKey = SUPA_KEY;
    </script>
    <style is:global>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg: #f5f5f4;
        --surface: #ffffff;
        --border: #e7e5e4;
        --border-strong: #d6d3d1;
        --ink: #1c1917;
        --muted: #78716c;
        --accent: #9f1239;
        --accent-soft: #fff1f2;
        --accent-strong: #be123c;
        --header-bg: #fafaf9;
        --row-hover: #fff7f7;
        --row-alt: #fafafa;
        --ok: #16a34a;
        --warn: #d97706;
        --danger: #dc2626;
      }

      html, body {
        width: 100%;
        height: 100dvh;
        background: var(--bg);
        color: var(--ink);
        font-family: "Aptos", "Inter", "Segoe UI", system-ui, sans-serif;
        font-size: 13px;
        overflow: hidden;
      }

      button, input, select, textarea {
        font: inherit;
        color: inherit;
      }

      button {
        cursor: pointer;
      }

      .app {
        display: flex;
        flex-direction: column;
        height: 100dvh;
        width: 100%;
      }

      /* ── Toolbar superior (compacto, una línea) ─────────────────────── */
      .toolbar {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 16px;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        flex-wrap: wrap;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        padding-right: 14px;
        border-right: 1px solid var(--border);
      }

      .brand img {
        height: 40px;
        width: auto;
        max-width: 110px;
        object-fit: contain;
        display: block;
      }

      .brand-meta {
        display: flex;
        flex-direction: column;
        line-height: 1.05;
      }

      .brand-title {
        font-family: Georgia, "Times New Roman", serif;
        font-size: 16px;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--ink);
        line-height: 1;
      }

      .brand-sub {
        font-size: 10px;
        letter-spacing: 0.18em;
        color: var(--muted);
        text-transform: uppercase;
        font-weight: 700;
        margin-top: 3px;
      }

      .toolbar-search {
        flex: 1 1 220px;
        min-width: 180px;
        max-width: 360px;
      }

      .toolbar-spacer {
        flex: 1;
      }

      .control {
        height: 32px;
        border: 1px solid var(--border-strong);
        border-radius: 6px;
        background: var(--surface);
        padding: 0 10px;
        outline: none;
        transition: border-color 140ms ease, box-shadow 140ms ease;
        font-size: 13px;
      }

      .control:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(190, 18, 60, 0.12);
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        height: 32px;
        padding: 0 12px;
        border: 1px solid var(--border-strong);
        border-radius: 6px;
        background: var(--surface);
        color: var(--ink);
        font-weight: 600;
        font-size: 12.5px;
        text-decoration: none;
        transition: background 140ms ease, border-color 140ms ease, color 140ms ease;
      }

      .btn:hover {
        background: var(--accent-soft);
        border-color: var(--accent);
        color: var(--accent);
      }

      .btn-primary {
        background: var(--accent);
        border-color: var(--accent);
        color: white;
      }

      .btn-primary:hover {
        background: var(--accent-strong);
        border-color: var(--accent-strong);
        color: white;
      }

      .btn .icon {
        font-size: 14px;
        line-height: 1;
      }

      /* ── Franja de KPIs (mini) ──────────────────────────────────────── */
      .kpis {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
      }

      .kpi {
        display: flex;
        align-items: baseline;
        gap: 10px;
        padding: 10px 16px;
        border-right: 1px solid var(--border);
        min-width: 0;
      }

      .kpi:last-child {
        border-right: 0;
      }

      .kpi-label {
        font-size: 10.5px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
        white-space: nowrap;
      }

      .kpi-value {
        font-family: Georgia, "Times New Roman", serif;
        font-size: 22px;
        font-weight: 700;
        line-height: 1;
        color: var(--ink);
        font-variant-numeric: tabular-nums;
      }

      .kpi-value.accent {
        color: var(--accent);
      }

      /* ── Resumen en cámara (por lote + variedad + productor) ───────── */
      .content-stack {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 0;
      }

      .camara-panel {
        flex-shrink: 0;
        max-height: 220px;
        overflow: auto;
        background: var(--header-bg);
        border-bottom: 1px solid var(--border-strong);
      }

      .camara-panel-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 8px 16px;
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        z-index: 2;
        background: var(--header-bg);
      }

      .camara-panel-head h2 {
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .camara-panel-meta {
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
      }

      .camara-table {
        width: 100%;
        min-width: 720px;
        border-collapse: collapse;
        table-layout: fixed;
      }

      .camara-table th,
      .camara-table td {
        padding: 8px 10px;
        text-align: center;
        border-bottom: 1px solid var(--border);
        border-right: 1px solid var(--border);
        font-size: 12px;
      }

      .camara-table th {
        background: #f3f0ec;
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--ink);
      }

      .camara-table th:last-child,
      .camara-table td:last-child {
        border-right: 0;
      }

      .camara-table tbody tr:nth-child(even) {
        background: rgba(255, 255, 255, 0.6);
      }

      .camara-table th.camara-col-banda,
      .camara-table td.camara-banda {
        width: 14%;
        max-width: 7.5rem;
        padding-left: 5px;
        padding-right: 5px;
        font-size: 11px;
        line-height: 1.25;
        letter-spacing: 0;
        text-transform: none;
        font-weight: 700;
        color: var(--ink);
      }

      .camara-table th.camara-col-banda {
        font-size: 10px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .camara-table td.camara-banda {
        white-space: normal;
        word-break: break-word;
        text-align: center;
        font-weight: 600;
      }

      .camara-table td.camara-lote {
        font-weight: 700;
        color: var(--ink);
      }

      .camara-empty {
        padding: 12px 16px;
        font-size: 12px;
        color: var(--muted);
        text-align: center;
      }

      /* ── Tabla (ocupa todo el espacio disponible) ───────────────────── */
      .table-wrap {
        flex: 1;
        overflow: auto;
        background: var(--surface);
      }

      table {
        width: 100%;
        min-width: 1910px;
        border-collapse: separate;
        border-spacing: 0;
        table-layout: fixed;
      }

      thead th {
        position: sticky;
        top: 0;
        z-index: 3;
        background: var(--header-bg);
        color: var(--ink);
        font-size: 10.5px;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        text-align: center;
        padding: 10px 8px;
        border-bottom: 2px solid var(--border-strong);
        border-right: 1px solid var(--border);
        white-space: nowrap;
        user-select: none;
      }

      thead th:last-child {
        border-right: 0;
      }

      thead .group-row th {
        z-index: 4;
        background: #f3f0ec;
        font-size: 10px;
        font-weight: 900;
        color: var(--accent);
        border-bottom: 1px solid var(--border);
        text-align: center;
        padding: 6px 8px;
        letter-spacing: 0.14em;
      }

      thead .head-row th {
        top: 28px;
      }

      tbody td {
        padding: 0;
        border-bottom: 1px solid var(--border);
        border-right: 1px solid var(--border);
        background: var(--surface);
        font-size: 12.5px;
        font-variant-numeric: tabular-nums;
        vertical-align: middle;
        text-align: center;
        white-space: nowrap;
      }

      tbody td:last-child {
        border-right: 0;
      }

      tbody tr:nth-child(even) td {
        background: var(--row-alt);
      }

      tbody tr:hover td {
        background: var(--row-hover);
      }

      tbody td input,
      tbody td textarea {
        width: 100%;
        height: 100%;
        min-height: 34px;
        border: 0;
        background: transparent;
        padding: 6px 8px;
        outline: none;
        font-size: 12.5px;
        color: var(--ink);
        font-variant-numeric: tabular-nums;
        text-align: center;
      }

      tbody td input[type="number"] {
        text-align: center;
        -moz-appearance: textfield;
      }

      tbody td input[type="number"]::-webkit-outer-spin-button,
      tbody td input[type="number"]::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
      }

      tbody td input:focus,
      tbody td textarea:focus {
        background: white;
        box-shadow: inset 0 0 0 2px var(--accent);
      }

      tbody td input.input-sum {
        font-variant-numeric: tabular-nums;
      }

      tbody td .cell-check {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 34px;
      }

      tbody td .cell-check input[type="checkbox"] {
        width: 16px;
        height: 16px;
        accent-color: var(--accent);
        cursor: pointer;
      }

      tbody td input.total-readonly {
        font-weight: 700;
        background: var(--header-bg);
        color: var(--ink);
        cursor: default;
      }

      tbody td input.total-readonly:focus {
        background: var(--header-bg);
        box-shadow: none;
      }

      tbody td textarea {
        resize: none;
        white-space: normal;
        font-size: 12px;
        line-height: 1.4;
      }

      .col-check { width: 44px; }
      .col-banda { width: 120px; }
      .col-fecha { width: 110px; }

      .head-row th.th-sort-fecha {
        cursor: pointer;
        user-select: none;
        transition: background 140ms ease, color 140ms ease;
      }

      .head-row th.th-sort-fecha:hover {
        background: #e8e4df;
        color: var(--accent);
      }

      .fecha-sort-ind {
        display: inline-block;
        margin-left: 4px;
        font-size: 11px;
        font-weight: 800;
        color: var(--accent);
        letter-spacing: 0;
      }

      .col-lote { width: 76px; }
      .col-productor { width: 150px; }
      .col-variedad { width: 110px; }
      .col-cajas { width: 72px; }
      .col-kilos-bruto { width: 96px; }
      .col-kilos-neto { width: 96px; }
      .col-total { width: 80px; }
      .col-calibre { width: 78px; }
      .col-defecto { width: 70px; }
      .col-clasif { width: 88px; }
      .col-calc { width: 108px; }

      .calibre-cell-wrap {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
      }

      .calibre-sub {
        font-size: 10px;
        font-weight: 600;
        color: var(--muted);
        line-height: 1.2;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .col-obs { width: 220px; }
      .col-img { width: 80px; }
      .col-accion { width: 60px; }

      .img-cell {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 4px;
      }

      .img-thumb {
        position: relative;
        width: 56px;
        height: 56px;
        border: 1px solid var(--border-strong);
        border-radius: 6px;
        overflow: hidden;
        background: var(--header-bg);
        cursor: pointer;
        transition: transform 140ms ease, border-color 140ms ease;
      }

      .img-thumb:hover {
        transform: scale(1.05);
        border-color: var(--accent);
      }

      .img-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .img-thumb .count {
        position: absolute;
        bottom: 2px;
        right: 2px;
        background: rgba(0, 0, 0, 0.75);
        color: white;
        font-size: 10px;
        font-weight: 800;
        padding: 1px 5px;
        border-radius: 999px;
      }

      .img-empty {
        color: var(--muted);
        font-size: 11px;
        font-weight: 700;
        opacity: 0.6;
      }

      /* ── Modal mapa cámara (edición desde tabla) ─────────────────── */
      .camara-modal {
        position: fixed;
        inset: 0;
        z-index: 110;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 16px;
      }

      .camara-modal.open {
        display: flex;
      }

      .camara-modal-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(15, 13, 12, 0.55);
        backdrop-filter: blur(4px);
      }

      .camara-modal-dialog {
        position: relative;
        z-index: 1;
        width: min(980px, 100%);
        max-height: min(92vh, 900px);
        overflow: auto;
        background: var(--surface);
        border: 1px solid var(--border-strong);
        border-radius: 14px;
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.18);
        display: flex;
        flex-direction: column;
      }

      .camara-modal-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        padding: 14px 16px 10px;
        border-bottom: 1px solid var(--border);
        background: var(--header-bg);
      }

      .camara-modal-header h2 {
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .camara-modal-sub {
        margin-top: 4px;
        font-size: 12px;
        font-weight: 600;
        color: var(--muted);
        line-height: 1.35;
      }

      .camara-modal-close {
        flex-shrink: 0;
        width: 36px;
        height: 36px;
        border: 1px solid var(--border-strong);
        border-radius: 8px;
        background: var(--surface);
        color: var(--ink);
        font-size: 20px;
        line-height: 1;
        cursor: pointer;
        transition: background 140ms ease, border-color 140ms ease, color 140ms ease;
      }

      .camara-modal-close:hover {
        background: var(--accent-soft);
        border-color: var(--accent);
        color: var(--accent);
      }

      .camara-modal-draft {
        padding: 8px 16px 0;
        font-size: 12px;
        font-weight: 700;
        color: var(--ink);
      }

      .la-torre-notice {
        margin: 0 20px 12px;
        padding: 12px 14px;
        border-radius: 8px;
        border: 1px solid rgb(251 191 36);
        background: rgb(254 252 232);
        color: rgb(120 53 15);
        font-size: 13px;
        font-weight: 600;
        line-height: 1.4;
      }

      .camara-modal-error {
        margin: 8px 16px 0;
        padding: 10px 12px;
        border-radius: 8px;
        border: 1px solid rgb(248 113 113);
        background: rgb(254 242 242);
        color: rgb(153 27 27);
        font-size: 12px;
        font-weight: 600;
        line-height: 1.4;
      }

      .camara-modal-map-root {
        padding: 10px 16px 14px;
        overflow-x: auto;
      }

      .camara-modal-footer {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        align-items: center;
        gap: 10px;
        padding: 12px 16px 14px;
        border-top: 1px solid var(--border);
        background: var(--header-bg);
      }

      #camara-modal-clear-selection {
        margin-right: auto;
      }

      /* ── Vista pantalla completa: kg por calibre (no modal centrado) ─ */
      .kg-calibre-full {
        position: fixed;
        inset: 0;
        z-index: 2000;
        box-sizing: border-box;
        display: none;
        flex-direction: column;
        width: 100vw;
        max-width: 100vw;
        min-height: 100vh;
        min-height: 100dvh;
        background: var(--surface);
      }

      .kg-calibre-full.open {
        display: flex;
      }

      .kg-calibre-full-head {
        flex-shrink: 0;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        padding: 14px 18px 12px;
        border-bottom: 1px solid var(--border);
        background: var(--header-bg);
      }

      .kg-calibre-full-head h2 {
        margin: 0;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .kg-calibre-full-sub {
        margin: 4px 0 0;
        font-size: 12px;
        font-weight: 600;
        color: var(--muted);
        line-height: 1.35;
      }

      .kg-calibre-hint {
        flex-shrink: 0;
        margin: 0;
        padding: 10px 18px;
        font-size: 12px;
        font-weight: 600;
        color: var(--muted);
        line-height: 1.45;
        border-bottom: 1px solid var(--border);
        background: var(--surface);
      }

      .kg-calibre-full-scroll {
        flex: 1;
        min-height: 0;
        padding: 12px 18px 18px;
        overflow: auto;
      }

      .kg-calibre-full-foot {
        flex-shrink: 0;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 10px;
        padding: 12px 18px 14px;
        border-top: 1px solid var(--border);
        background: var(--header-bg);
      }

      .kg-calibre-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
        font-variant-numeric: tabular-nums;
      }

      .kg-calibre-table th,
      .kg-calibre-table td {
        border: 1px solid var(--border);
        padding: 8px 10px;
        text-align: right;
        white-space: nowrap;
      }

      .kg-calibre-table th:first-child,
      .kg-calibre-table td:first-child,
      .kg-calibre-table th:nth-child(2),
      .kg-calibre-table td:nth-child(2) {
        text-align: left;
        white-space: normal;
        min-width: 7rem;
      }

      .kg-calibre-table thead th {
        background: var(--header-bg);
        font-weight: 800;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        font-size: 10px;
        color: var(--accent);
      }

      .kg-calibre-table tbody tr:nth-child(even) {
        background: var(--row-alt);
      }

      .kg-calibre-table tfoot td {
        font-weight: 800;
        background: #e7e5e4;
        color: var(--ink);
      }

      .kg-calibre-empty-msg {
        margin: 0;
        padding: 16px 4px 8px;
        font-size: 13px;
        font-weight: 600;
        color: var(--muted);
        line-height: 1.45;
      }

      tbody td input.input-banda-map {
        cursor: pointer;
        background: #fafaf9;
      }

      tbody td input.input-banda-map:hover:not(:disabled) {
        border-color: var(--accent);
        background: var(--accent-soft);
      }

      tbody td input.input-banda-map:disabled {
        cursor: not-allowed;
        opacity: 0.55;
      }

      /* ── Lightbox ─────────────────────────────────────────────────── */
      .lightbox {
        position: fixed;
        inset: 0;
        z-index: 100;
        background: rgba(15, 13, 12, 0.88);
        display: none;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 24px;
        backdrop-filter: blur(6px);
      }

      .lightbox.open {
        display: flex;
      }

      .lightbox-img {
        max-width: 92vw;
        max-height: 78vh;
        object-fit: contain;
        border-radius: 8px;
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.4);
        background: white;
      }

      .lightbox-info {
        margin-top: 14px;
        color: white;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-shadow: 0 2px 6px rgba(0, 0, 0, 0.5);
      }

      .lightbox-close {
        position: absolute;
        top: 16px;
        right: 16px;
        width: 38px;
        height: 38px;
        border: 0;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.16);
        color: white;
        font-size: 22px;
        line-height: 1;
        cursor: pointer;
        transition: background 140ms ease;
      }

      .lightbox-close:hover {
        background: var(--danger);
      }

      .lightbox-nav {
        display: flex;
        gap: 14px;
        margin-top: 12px;
      }

      .lightbox-nav button {
        height: 36px;
        padding: 0 16px;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        background: rgba(255, 255, 255, 0.08);
        color: white;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
      }

      .lightbox-nav button:hover {
        background: rgba(255, 255, 255, 0.18);
      }

      .lightbox-nav button:disabled {
        opacity: 0.4;
        cursor: not-allowed;
      }

      .cell-calc {
        display: block;
        padding: 8px;
        text-align: center;
        font-weight: 700;
        font-size: 11px;
        line-height: 1.25;
        white-space: normal;
        color: var(--ink);
        background: #fafafa;
      }

      tbody tr:nth-child(even) .cell-calc {
        background: #f4f4f3;
      }

      .icon-btn {
        width: 28px;
        height: 28px;
        margin: 4px auto;
        display: flex;
        align-items: center;
        justify-content: center;
        background: transparent;
        border: 1px solid transparent;
        border-radius: 6px;
        color: var(--muted);
        font-size: 14px;
        transition: background 140ms ease, color 140ms ease, border-color 140ms ease;
      }

      .icon-btn:hover {
        background: #fee2e2;
        border-color: #fecaca;
        color: var(--danger);
      }

      /* ── Empty state ────────────────────────────────────────────────── */
      .empty {
        padding: 60px 20px;
        text-align: center;
        color: var(--muted);
      }

      .empty strong {
        display: block;
        font-family: Georgia, "Times New Roman", serif;
        color: var(--ink);
        font-size: 18px;
        margin-bottom: 6px;
      }

      /* ── Responsive ─────────────────────────────────────────────────── */
      @media (max-width: 900px) {
        .kpis {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
        .kpi:nth-child(2) {
          border-right: 0;
        }
        .kpi {
          border-bottom: 1px solid var(--border);
        }
        .kpi:nth-last-child(-n+2) {
          border-bottom: 0;
        }
      }

      @media (max-width: 640px) {
        .toolbar {
          padding: 8px 10px;
          gap: 8px;
        }
        .brand { padding-right: 10px; gap: 8px; }
        .brand img { height: 32px; max-width: 90px; }
        .brand-title { font-size: 14px; }
        .brand-sub { font-size: 9.5px; letter-spacing: 0.14em; }
        .toolbar-search { max-width: 100%; }
      }

      /* ── Mapa de cámara frigorífica ───────────────────────────────── */
      .fridge-map-panel {
        flex-shrink: 0;
        max-height: min(380px, 42vh);
        overflow: auto;
        background: linear-gradient(180deg, #fafaf9 0%, #f5f2ef 100%);
        border-bottom: 1px solid var(--border-strong);
      }

      .fridge-map-panel.is-collapsed {
        max-height: none;
        overflow: visible;
      }

      .fridge-map-panel.is-collapsed #fridge-map-root,
      .fridge-map-panel.is-collapsed .map-print-stamp {
        display: none !important;
      }

      .fridge-map-panel.is-collapsed .fridge-map-meta {
        display: none;
      }

      .fridge-map-collapsed-note {
        display: none;
        margin: 0;
        padding: 0 16px 8px;
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
        line-height: 1.35;
      }

      .fridge-map-panel.is-collapsed .fridge-map-collapsed-note {
        display: block;
      }

      .fridge-map-head {
        display: flex;
        flex-direction: column;
        align-items: stretch;
        gap: 6px;
        padding: 8px 16px;
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        z-index: 2;
        background: rgba(250, 250, 249, 0.96);
      }

      .fridge-map-head-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
      }

      .fridge-map-toggle {
        flex-shrink: 0;
        padding: 6px 12px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.04em;
      }

      .fridge-map-head h2 {
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .fridge-map-meta {
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
        width: 100%;
        line-height: 1.35;
      }

      .map-print-stamp {
        display: none;
      }

      #fridge-map-root {
        padding: 10px 16px 12px;
      }

      .lt-fridge-root {
        max-width: 1400px;
        margin: 0 auto;
      }

      .lt-fridge-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 10px 16px;
        margin-bottom: 10px;
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
      }

      .lt-leg {
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }

      .lt-leg::before {
        content: "";
        width: 12px;
        height: 12px;
        border-radius: 2px;
        border: 1px solid var(--border-strong);
      }

      .lt-leg-free::before {
        background: #f5f5f4;
      }

      .lt-leg-occ::before {
        background: #e0e7ff;
        border-color: #6366f1;
      }

      .lt-leg-dbl::before {
        background: linear-gradient(180deg, #c7d2fe 50%, #a5b4fc 50%);
        border-color: #4338ca;
      }

      .lt-leg-depth::before {
        background: #e0f2fe;
        border-color: #0284c7;
      }

      .lt-leg-b1::before {
        background: #fce7f3;
        border-color: #db2777;
      }

      .lt-leg-multi::before {
        background: #dbeafe;
        border-color: #1d4ed8;
      }

      .lt-fridge-slot--ghost {
        background: linear-gradient(180deg, #eff6ff 0%, #dbeafe 100%);
        border-color: #3b82f6;
      }

      .lt-fridge-slot--draft-toggle {
        outline: 2px dashed #1d4ed8;
        outline-offset: 1px;
      }

      .lt-fridge-colhead--b1 {
        color: #9d174d;
      }

      .lt-fridge-slot--na {
        background: #f4f4f5;
        opacity: 0.75;
      }

      .lt-fridge-grid {
        display: grid;
        gap: 3px;
        align-items: stretch;
      }

      .lt-fridge-corner,
      .lt-fridge-colhead,
      .lt-fridge-rowhead {
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
        padding: 4px 2px;
        text-align: center;
        line-height: 1.15;
      }

      .lt-fridge-rowhead {
        justify-content: flex-end;
        padding-right: 6px;
      }

      .lt-fridge-cell {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-height: 72px;
      }

      .lt-fridge-cell--double {
        outline: 2px solid #4338ca;
        outline-offset: 1px;
        border-radius: 2px;
      }

      .lt-fridge-slot {
        flex: 1;
        min-height: 32px;
        border: 1px solid var(--border-strong);
        border-radius: 2px;
        background: #fafaf9;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1px;
        padding: 3px 4px;
        text-align: center;
        transition: background 140ms ease, border-color 140ms ease;
      }

      button.lt-fridge-slot {
        font: inherit;
        cursor: pointer;
      }

      .lt-fridge-slot--empty {
        background: #f5f5f4;
      }

      .lt-fridge-slot--blocked {
        background: #e7e5e4;
        color: var(--muted);
        cursor: not-allowed;
        opacity: 0.75;
      }

      .lt-fridge-slot--occupied {
        background: linear-gradient(180deg, #eef2ff 0%, #e0e7ff 100%);
        border-color: #818cf8;
        color: var(--ink);
      }

      .lt-fridge-slot--picked {
        outline: 2px solid var(--accent);
        outline-offset: 1px;
        border-color: var(--accent);
        box-shadow: 0 0 0 2px rgba(159, 18, 57, 0.12);
      }

      .lt-slot-coord {
        font-size: 9px;
        font-weight: 800;
        letter-spacing: 0.04em;
        color: #4338ca;
      }

      .lt-slot-fruit {
        font-size: 10px;
        font-weight: 700;
        line-height: 1.1;
        max-width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .lt-slot-lote {
        font-size: 9px;
        font-weight: 700;
        color: var(--muted);
        font-variant-numeric: tabular-nums;
      }

      .lt-slot-prod {
        font-size: 8px;
        color: var(--muted);
        max-width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .lt-slot-free-label {
        font-size: 9px;
        font-weight: 700;
        color: #a8a29e;
      }

      .lt-slot-blocked-label {
        font-size: 9px;
        font-weight: 800;
        color: #78716c;
      }

      .lt-fridge-foot {
        margin-top: 10px;
        text-align: center;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
      }

      @media print {
        @page {
          size: landscape;
          margin: 10mm;
        }

        body.printing-fridge-map .toolbar,
        body.printing-fridge-map .kpis,
        body.printing-fridge-map .content-stack,
        body.printing-fridge-map .lightbox {
          display: none !important;
        }

        body.printing-fridge-map #camara-modal {
          display: none !important;
        }

        body.printing-fridge-map #kg-calibre-modal {
          display: none !important;
        }

        body.printing-fridge-map #fridge-map-panel {
          display: block !important;
          position: relative;
          width: 100%;
          max-height: none;
          overflow: visible;
          background: white;
          border: 0;
          page-break-inside: avoid;
        }

        body.printing-fridge-map .map-print-stamp {
          display: block !important;
          margin: 0 16px 10px;
          font-size: 11px;
          font-weight: 700;
          color: #1c1917;
        }

        .lt-fridge-slot--picked {
          box-shadow: none;
        }
      }
    </style>
  </head>
  <body>
    <div class="app">
      <header class="toolbar">
        <div class="brand">
          <img src={withBase("/img/logo-la-torre-stone-fruit.png")} alt="La Torre Stone Fruits" />
          <div class="brand-meta">
            <div class="brand-title">LA TORRE 2026</div>
            <div class="brand-sub">Muestras · cereza</div>
          </div>
        </div>

        <input class="control toolbar-search" id="search-input" type="search" placeholder="Buscar lote, productor, variedad..." />

        <select class="control" id="status-filter" aria-label="Filtrar por estado">
          <option value="todos">Todos</option>
          <option value="ok">OK</option>
          <option value="alerta">Alerta</option>
          <option value="critico">Crítico</option>
        </select>

        <div class="toolbar-spacer"></div>

        <button class="btn" id="export-excel" type="button">
          <span class="icon">⇩</span> Excel
        </button>
        <button class="btn" id="btn-print-fridge-map" type="button" title="Imprimir solo el mapa de cámara (horizontal)">
          Imprimir mapa
        </button>
        <button class="btn" id="btn-kg-calibre-disponible" type="button" title="Abre vista a pantalla completa: kg neto por calibre (variedad + productor, no procesados)">
          Kg por calibre
        </button>
        <a class="btn btn-primary" href={withBase("/la-torre-2026/nuevo")}>
          <span class="icon">+</span> Nuevo lote
        </a>
      </header>

      <div id="la-torre-notice" class="la-torre-notice" hidden role="alert"></div>

      <section class="kpis" aria-label="Resumen">
        <div class="kpi">
          <span class="kpi-label">Muestras</span>
          <span class="kpi-value" id="metric-samples">0</span>
        </div>
        <div class="kpi">
          <span class="kpi-label">Frutos</span>
          <span class="kpi-value" id="metric-fruits">0</span>
        </div>
        <div class="kpi">
          <span class="kpi-label">% Exportable</span>
          <span class="kpi-value accent" id="metric-exportable">0%</span>
        </div>
        <div class="kpi">
          <span class="kpi-label">% Defectos</span>
          <span class="kpi-value accent" id="metric-defects">0%</span>
        </div>
      </section>

      <section class="fridge-map-panel is-collapsed" id="fridge-map-panel" aria-labelledby="fridge-map-title">
        <div class="fridge-map-head">
          <div class="fridge-map-head-row">
            <h2 id="fridge-map-title">Mapa de cámara frigorífica</h2>
            <button
              type="button"
              class="btn fridge-map-toggle"
              id="btn-toggle-fridge-map"
              aria-expanded="false"
              aria-controls="fridge-map-root"
            >
              Mostrar mapa
            </button>
          </div>
          <span class="fridge-map-meta">Vista superior · Solo pallets en cámara (no procesados). Coordenadas B–P–H.</span>
        </div>
        <p class="fridge-map-collapsed-note" id="fridge-map-collapsed-note">
          Mapa oculto para ganar espacio en pantalla. Pulse «Mostrar mapa» arriba para ver el plano de nuevo.
        </p>
        <div class="map-print-stamp" id="map-print-stamp" aria-hidden="true"></div>
        <div id="fridge-map-root"></div>
      </section>

      <div class="content-stack">
        <section class="camara-panel" aria-labelledby="camara-resumen-title">
          <div class="camara-panel-head">
            <h2 id="camara-resumen-title">Resumen en cámara</h2>
            <span class="camara-panel-meta" id="camara-panel-meta"></span>
          </div>
          <table class="camara-table">
            <thead>
              <tr>
                <th style="width: 10%;">Lote</th>
                <th style="width: 14%;">Variedad</th>
                <th style="width: 22%;">Productor</th>
                <th class="camara-col-banda" title="Coordenada en cámara (B horizontal, P profundidad). B1: máx. 3 posiciones; puerta al final de B1">Banda</th>
                <th style="width: 11%;">Total cajas</th>
                <th style="width: 11%;">Total kg bruto</th>
                <th style="width: 11%;">Total kg neto</th>
                <th style="width: 9%;">Frutos</th>
                <th style="width: 7%;">Proc.</th>
              </tr>
            </thead>
            <tbody id="camara-resumen-body"></tbody>
          </table>
          <p class="camara-empty" id="camara-empty" hidden>No hay muestras con lote indicado aún.</p>
        </section>

      <div class="table-wrap">
        <table id="samples-table">
          <colgroup>
            <col class="col-check" />
            <col class="col-banda" />
            <col class="col-fecha" />
            <col class="col-lote" />
            <col class="col-productor" />
            <col class="col-variedad" />
            <col class="col-cajas" />
            <col class="col-kilos-bruto" />
            <col class="col-kilos-neto" />
            <col class="col-total" />
            <col class="col-calibre" />
            <col class="col-calibre" />
            <col class="col-calibre" />
            <col class="col-calibre" />
            <col class="col-calibre" />
            <col class="col-calibre" />
            <col class="col-calibre" />
            <col class="col-defecto" />
            <col class="col-defecto" />
            <col class="col-defecto" />
            <col class="col-defecto" />
            <col class="col-defecto" />
            <col class="col-defecto" />
            <col class="col-defecto" />
            <col class="col-defecto" />
            <col class="col-defecto" />
            <col class="col-defecto" />
            <col class="col-clasif" />
            <col class="col-clasif" />
            <col class="col-clasif" />
            <col class="col-calc" />
            <col class="col-calc" />
            <col class="col-calc" />
            <col class="col-obs" />
            <col class="col-img" />
            <col class="col-img" />
            <col class="col-accion" />
          </colgroup>
          <thead>
            <tr class="group-row">
              <th colspan="9">Identificación</th>
              <th>Total</th>
              <th colspan="7">Calibres (mm)</th>
              <th colspan="10">Defectos</th>
              <th colspan="3">Clasificación (calc.)</th>
              <th colspan="3">Cálculos</th>
              <th>Observaciones</th>
              <th colspan="2">Imágenes</th>
              <th></th>
            </tr>
            <tr class="head-row">
              <th title="Marcar cuando el lote ya fue procesado">✓</th>
              <th title="Clic: B1 solo 3 posiciones en P; puerta al final de B1. B2–B12 más profundidad. P1 fondo → cara acceso">Banda</th>
              <th
                class="th-sort-fecha"
                id="th-sort-fecha"
                scope="col"
                role="button"
                tabindex="0"
              >
                Fecha<span id="fecha-sort-indicator" class="fecha-sort-ind" aria-hidden="true"></span>
              </th>
              <th>Lote</th>
              <th>Productor</th>
              <th>Variedad</th>
              <th>Cajas</th>
              <th>Kilos bruto</th>
              <th>Kilos neto</th>
              <th>Frutos</th>
              <th title="Frutos en ese calibre; debajo % del total y kg neto del lote (proporcional)">P/C</th>
              <th title="Frutos en ese calibre; debajo % del total y kg neto del lote (proporcional)">22-24</th>
              <th title="Frutos en ese calibre; debajo % del total y kg neto del lote (proporcional)">24-26</th>
              <th title="Frutos en ese calibre; debajo % del total y kg neto del lote (proporcional)">26-28</th>
              <th title="Frutos en ese calibre; debajo % del total y kg neto del lote (proporcional)">28-30</th>
              <th title="Frutos en ese calibre; debajo % del total y kg neto del lote (proporcional)">30-32</th>
              <th title="Frutos en ese calibre; debajo % del total y kg neto del lote (proporcional)">+34</th>
              <th>Blanda</th>
              <th>Pitting</th>
              <th>Doble</th>
              <th>Deshid.</th>
              <th>Partida</th>
              <th>Pudric.</th>
              <th>F. color</th>
              <th>M. luna</th>
              <th>S. pedic.</th>
              <th>Negro</th>
              <th title="Frutos; debajo % del total y kg neto del lote (proporcional)">Primera</th>
              <th title="Frutos; debajo % del total y kg neto del lote (proporcional)">Segunda</th>
              <th title="Frutos; debajo % del total y kg neto del lote (proporcional)">Zumo</th>
              <th title="% sobre total de frutos y kg neto del lote atribuidos (proporcional a frutos defectuosos)">% Def.</th>
              <th title="% sobre total de frutos y kg neto del lote atribuidos (frutos no zumo)">% Exp.</th>
              <th>Prom.</th>
              <th>Observaciones</th>
              <th>Etiqueta</th>
              <th>Defectos</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="samples-body"></tbody>
        </table>
        <div class="empty" id="empty-state" hidden>
          <strong>Sin muestras que mostrar</strong>
          Ajusta los filtros o agrega una nueva muestra.
        </div>
      </div>
      </div>

    </div>

    <div class="lightbox" id="lightbox" aria-hidden="true">
      <button class="lightbox-close" type="button" id="lightbox-close" aria-label="Cerrar">×</button>
      <img class="lightbox-img" id="lightbox-img" alt="" />
      <div class="lightbox-info" id="lightbox-info"></div>
      <div class="lightbox-nav">
        <button type="button" id="lightbox-prev">← Anterior</button>
        <button type="button" id="lightbox-next">Siguiente →</button>
      </div>
    </div>

    <div id="camara-modal" class="camara-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="camara-modal-title">
      <div class="camara-modal-backdrop" id="camara-modal-backdrop"></div>
      <div class="camara-modal-dialog">
        <header class="camara-modal-header">
          <div>
            <h2 id="camara-modal-title">Posición en cámara</h2>
            <p id="camara-modal-subtitle" class="camara-modal-sub"></p>
          </div>
          <button type="button" class="camara-modal-close" id="camara-modal-close" aria-label="Cerrar">×</button>
        </header>
        <p id="camara-modal-draft" class="camara-modal-draft"></p>
        <div id="camara-modal-error" class="camara-modal-error" hidden role="alert"></div>
        <div id="camara-modal-map-root" class="camara-modal-map-root"></div>
        <footer class="camara-modal-footer">
          <button type="button" class="btn" id="camara-modal-clear-selection">Vaciar selección</button>
          <button type="button" class="btn" id="camara-modal-cancel">Cancelar</button>
          <button type="button" class="btn btn-primary" id="camara-modal-confirm" disabled>Guardar posición</button>
        </footer>
      </div>
    </div>

    <div id="kg-calibre-modal" class="kg-calibre-full" aria-hidden="true" role="region" aria-labelledby="kg-calibre-modal-title">
      <header class="kg-calibre-full-head">
        <div>
          <h2 id="kg-calibre-modal-title">Kg neto por calibre (disponible)</h2>
          <p class="kg-calibre-full-sub">Vista pantalla completa · Agrupado por variedad y productor · Solo muestras no procesadas</p>
        </div>
        <button type="button" class="camara-modal-close" id="kg-calibre-modal-close" aria-label="Cerrar">×</button>
      </header>
      <p class="kg-calibre-hint">
        Para cada muestra, los kg por calibre se calculan igual que en la tabla principal: kg neto del lote × (frutos en ese calibre ÷ total de frutos de la muestra). Aquí se suman esas cantidades entre todos los lotes de la misma combinación variedad + productor.
      </p>
      <div class="kg-calibre-full-scroll" id="kg-calibre-modal-body"></div>
      <footer class="kg-calibre-full-foot">
        <button type="button" class="btn btn-primary" id="kg-calibre-modal-cerrar">Cerrar</button>
      </footer>
    </div>

    <script is:inline src={withBase("/js/fruitstone-camara-map.js")}></script>
    <script is:inline>
      const TABLE = "fruitstone2026_muestras";
      const supa = window.supabase && window._supaUrl && window._supaKey
        ? window.supabase.createClient(window._supaUrl, window._supaKey)
        : null;

      const idColumns = [
        { key: "fecha", kind: "text", type: "date" },
        { key: "lote", kind: "text", type: "text" },
        { key: "productor", kind: "text", type: "text" },
        { key: "variedad", kind: "text", type: "text" }
      ];

      const CALIBRE_KEYS = ["cPre", "c22", "c24", "c26", "c28", "c30", "c32"];
      const CALIBRE_AGG_LABELS = [
        { key: "cPre", label: "P/C" },
        { key: "c22", label: "22-24" },
        { key: "c24", label: "24-26" },
        { key: "c26", label: "26-28" },
        { key: "c28", label: "28-30" },
        { key: "c30", label: "30-32" },
        { key: "c32", label: "+34" }
      ];
      const DEFECTO_KEYS = [
        "blanda",
        "pitting",
        "doble",
        "deshidratada",
        "partida",
        "pudricion",
        "colorBajo",
        "mediaLuna",
        "sinPedicelo",
        "negro"
      ];
      const ZUMO_KEYS = ["pudricion", "colorBajo", "partida", "negro"];
      const SEGUNDA_KEYS = ["blanda", "pitting", "doble"];

      const numberFields = [...CALIBRE_KEYS, ...DEFECTO_KEYS];

      function sumCalibres(row) {
        return CALIBRE_KEYS.reduce((acc, k) => acc + asNumber(row[k]), 0);
      }

      function sumZumo(row) {
        return ZUMO_KEYS.reduce((acc, k) => acc + asNumber(row[k]), 0);
      }

      function sumSegunda(row) {
        return SEGUNDA_KEYS.reduce((acc, k) => acc + asNumber(row[k]), 0);
      }

      function sumPrimera(row) {
        return Math.max(0, asNumber(row.total) - sumZumo(row) - sumSegunda(row));
      }

      const fieldToColumn = {
        procesado: "procesado",
        bandasCamara: "bandas_camara",
        camaraBanda: "camara_banda",
        camaraPosicion: "camara_posicion",
        camaraAltura: "camara_altura",
        fecha: "fecha",
        lote: "lote",
        productor: "productor",
        variedad: "variedad",
        cantidadCajas: "cantidad_cajas",
        kilosBrutoLote: "kilos_bruto_lote",
        kilosNetoLote: "kilos_neto_lote",
        total: "total",
        cPre: "c_pre",
        c22: "c22",
        c24: "c24",
        c26: "c26",
        c28: "c28",
        c30: "c30",
        c32: "c32",
        blanda: "blanda",
        pitting: "pitting",
        doble: "doble",
        deshidratada: "deshidratada",
        partida: "partida",
        pudricion: "pudricion",
        colorBajo: "color_bajo",
        mediaLuna: "media_luna",
        sinPedicelo: "sin_pedicelo",
        negro: "negro",
        primera: "primera",
        segunda: "segunda",
        zumo: "zumo",
        observaciones: "observaciones"
      };

      let rows = [];
      /** @type {"ingreso" | "fecha"} */
      let tableSortMode = "ingreso";

      function rowIndexById(id) {
        if (id == null) return -1;
        const sid = String(id);
        return rows.findIndex((r) => String(r.id) === sid);
      }

      function compareIngresoOrder(a, b) {
        const ta = a.createdAt ? new Date(a.createdAt).getTime() : 0;
        const tb = b.createdAt ? new Date(b.createdAt).getTime() : 0;
        if (ta !== tb) return ta - tb;
        return (Number(a.id) || 0) - (Number(b.id) || 0);
      }

      function fechaMuestraSortKey(fechaVal) {
        const raw = String(fechaVal ?? "").trim();
        if (!raw) return Number.MAX_SAFE_INTEGER;
        const t = Date.parse(raw);
        return Number.isFinite(t) ? t : Number.MAX_SAFE_INTEGER;
      }

      function applyTableSort() {
        if (tableSortMode === "fecha") {
          rows.sort((a, b) => {
            const d = fechaMuestraSortKey(a.fecha) - fechaMuestraSortKey(b.fecha);
            if (d !== 0) return d;
            return compareIngresoOrder(a, b);
          });
        } else {
          rows.sort(compareIngresoOrder);
        }
      }

      function syncFechaSortHeader() {
        const th = document.getElementById("th-sort-fecha");
        const ind = document.getElementById("fecha-sort-indicator");
        if (!th) return;
        if (tableSortMode === "fecha") {
          th.title = "Orden: fecha de muestra (más antigua primero). Clic para volver al orden de ingreso.";
          th.setAttribute("aria-sort", "ascending");
          if (ind) ind.textContent = "↑";
        } else {
          th.title =
            "Orden: como se ingresaron (arriba = lo guardado antes). Clic para ordenar por fecha de muestra, más antigua primero.";
          th.removeAttribute("aria-sort");
          if (ind) ind.textContent = "";
        }
      }

      function handleFechaSortHeaderToggle() {
        tableSortMode = tableSortMode === "fecha" ? "ingreso" : "fecha";
        applyTableSort();
        syncFechaSortHeader();
        render();
      }

      const tbody = document.getElementById("samples-body");
      const emptyState = document.getElementById("empty-state");
      const searchInput = document.getElementById("search-input");
      const statusFilter = document.getElementById("status-filter");

      function rowFromDb(r) {
        return {
          id: r.id,
          createdAt: r.created_at ?? null,
          procesado: r.procesado === true,
          bandasCamara: r.bandas_camara ?? "",
          camaraBanda: r.camara_banda != null ? Number(r.camara_banda) : null,
          camaraPosicion: r.camara_posicion != null ? Number(r.camara_posicion) : null,
          camaraAltura: r.camara_altura != null ? Number(r.camara_altura) : null,
          fecha: r.fecha ?? "",
          lote: r.lote ?? "",
          productor: r.productor ?? "",
          variedad: r.variedad ?? "",
          cantidadCajas: r.cantidad_cajas != null ? Number(r.cantidad_cajas) : null,
          kilosBrutoLote: r.kilos_bruto_lote != null ? Number(r.kilos_bruto_lote) : null,
          kilosNetoLote: r.kilos_neto_lote != null ? Number(r.kilos_neto_lote) : null,
          total: r.total ?? 0,
          cPre: r.c_pre ?? 0,
          c22: r.c22 ?? 0,
          c24: r.c24 ?? 0,
          c26: r.c26 ?? 0,
          c28: r.c28 ?? 0,
          c30: r.c30 ?? 0,
          c32: r.c32 ?? 0,
          blanda: r.blanda ?? 0,
          pitting: r.pitting ?? 0,
          doble: r.doble ?? 0,
          deshidratada: r.deshidratada ?? 0,
          partida: r.partida ?? 0,
          pudricion: r.pudricion ?? 0,
          colorBajo: r.color_bajo ?? 0,
          mediaLuna: r.media_luna ?? 0,
          sinPedicelo: r.sin_pedicelo ?? 0,
          negro: r.negro ?? 0,
          primera: r.primera ?? 0,
          segunda: r.segunda ?? 0,
          zumo: r.zumo ?? 0,
          observaciones: r.observaciones ?? "",
          etiquetaPallet: r.etiqueta_pallet ?? "",
          fotosDefectos: Array.isArray(r.fotos_defectos) ? r.fotos_defectos : []
        };
      }

      async function loadRows() {
        if (!supa) return;
        const { data, error } = await supa
          .from(TABLE)
          .select("*")
          .order("created_at", { ascending: true });
        if (error) {
          console.error("Error cargando muestras:", error);
          return;
        }
        rows = (data ?? []).map(rowFromDb);
        applyTableSort();
        syncFechaSortHeader();
        render();
      }

      const pendingPatches = new Map();
      const debounceTimers = new Map();
      const UPDATE_DEBOUNCE_MS = 250;

      function takePendingSnapshotAndClearTimers() {
        const entries = Array.from(pendingPatches.entries());
        if (!entries.length) return null;
        for (const [id] of entries) {
          const t = debounceTimers.get(id);
          if (t) clearTimeout(t);
          debounceTimers.delete(id);
        }
        pendingPatches.clear();
        return entries;
      }

      /**
       * Normaliza columnas de cámara antes de PATCH: si la BD tiene NOT NULL en
       * `camara_altura`, sin posición en mapa debe persistirse como 1, nunca null.
       */
      function normalizeFruitstoneCamaraPatch(patch) {
        if (!patch || typeof patch !== "object") return patch;
        const keys = Object.keys(patch);
        const touches =
          keys.includes("camara_banda") ||
          keys.includes("camara_posicion") ||
          keys.includes("camara_altura") ||
          keys.includes("bandas_camara");
        if (!touches) return patch;
        const b = patch["camara_banda"];
        const p = patch["camara_posicion"];
        const rawBt = patch["bandas_camara"];
        const hasStruct = b != null && p != null;
        const hasTxt = rawBt != null && String(rawBt).trim() !== "";
        if (!hasStruct && !hasTxt) {
          patch["camara_banda"] = null;
          patch["camara_posicion"] = null;
          patch["camara_altura"] = 1;
          patch["bandas_camara"] = null;
          return patch;
        }
        if (!hasStruct && (patch["camara_altura"] == null || patch["camara_altura"] === "")) {
          patch["camara_altura"] = 1;
        }
        return patch;
      }

      /** Envío síncrono a la API REST de Supabase (soporta keepalive al cerrar/recargar pestaña). */
      function sendPatchesKeepalive(entries) {
        const base = typeof window !== "undefined" ? window._supaUrl : "";
        const key = typeof window !== "undefined" ? window._supaKey : "";
        if (!base || !key || !entries || !entries.length) return;
        for (const [id, patch] of entries) {
          normalizeFruitstoneCamaraPatch(patch);
          const url = `${base}/rest/v1/${TABLE}?id=eq.${encodeURIComponent(String(id))}`;
          fetch(url, {
            method: "PATCH",
            headers: {
              apikey: key,
              Authorization: `Bearer ${key}`,
              "Content-Type": "application/json",
              Prefer: "return=minimal",
            },
            body: JSON.stringify(patch),
            keepalive: true,
          }).catch(() => {});
        }
      }

      /**
       * Persiste todos los cambios pendientes (p. ej. cámara + otros campos en cola).
       * @returns {{ ok: true, empty?: boolean, skippedNoClient?: boolean } | { ok: false, error: { message?: string } }}
       */
      async function flushAllPendingPatches() {
        if (!supa) return { ok: true, skippedNoClient: true };
        const entries = takePendingSnapshotAndClearTimers();
        if (!entries) return { ok: true, empty: true };
        sendPatchesKeepalive(entries);
        const results = await Promise.all(
          entries.map(([id, patch]) => {
            normalizeFruitstoneCamaraPatch(patch);
            return supa.from(TABLE).update(patch).eq("id", id);
          })
        );
        const failed = results.find((r) => r.error);
        if (failed && failed.error) {
          if (typeof process !== "undefined" && process.env.NODE_ENV === "development") {
            console.error("Error actualizando muestra:", failed.error);
          }
          for (let ri = 0; ri < entries.length; ri++) {
            const id = entries[ri][0];
            const patch = entries[ri][1];
            const cur = pendingPatches.get(id) ?? {};
            pendingPatches.set(id, Object.assign({}, cur, patch));
          }
          return { ok: false, error: failed.error };
        }
        return { ok: true, count: entries.length };
      }

      function scheduleUpdate(rowIndex, field, value) {
        const row = rows[rowIndex];
        if (!row || !row.id || !supa) return;
        const column = fieldToColumn[field];
        if (!column) return;
        const patch = pendingPatches.get(row.id) ?? {};
        patch[column] = value;
        pendingPatches.set(row.id, patch);

        const existing = debounceTimers.get(row.id);
        if (existing) clearTimeout(existing);
        debounceTimers.set(row.id, setTimeout(() => flushUpdate(row.id), UPDATE_DEBOUNCE_MS));
      }

      async function flushUpdate(id) {
        const patch = pendingPatches.get(id);
        if (!patch || !supa) return;
        pendingPatches.delete(id);
        debounceTimers.delete(id);
        normalizeFruitstoneCamaraPatch(patch);
        const { error } = await supa.from(TABLE).update(patch).eq("id", id);
        if (error && typeof process !== "undefined" && process.env.NODE_ENV === "development") {
          console.error("Error actualizando muestra:", error);
        }
      }

      async function deleteRow(rowIndex) {
        const row = rows[rowIndex];
        if (!row || !supa) return;
        if (row.id) {
          const { error } = await supa.from(TABLE).delete().eq("id", row.id);
          if (error) {
            console.error("Error eliminando muestra:", error);
            return;
          }
        }
        rows.splice(rowIndex, 1);
        render();
      }

      function asNumber(value) {
        const n = Number(value);
        return Number.isFinite(n) ? n : 0;
      }

      function pct(value, total) {
        if (!total) return 0;
        return (value / total) * 100;
      }

      function formatPct(value) {
        return `${value.toLocaleString("es-CL", { maximumFractionDigits: 1 })}%`;
      }

      /** Kg neto del lote atribuibles a `shareNumerator` frutos (misma muestra). */
      function kgNetoShare(row, shareNumerator) {
        const total = asNumber(row.total);
        const net = row.kilosNetoLote != null && Number.isFinite(Number(row.kilosNetoLote)) ? Number(row.kilosNetoLote) : null;
        if (total <= 0 || net == null) return null;
        return (asNumber(shareNumerator) / total) * net;
      }

      function fmtKgDisponibleCell(n) {
        if (n == null || !Number.isFinite(n) || n <= 0) return "—";
        return n.toLocaleString("es-CL", { minimumFractionDigits: 0, maximumFractionDigits: 2 });
      }

      /**
       * Agrupa muestras no procesadas (con total de frutos > 0) por variedad + productor
       * y acumula kg neto por calibre (misma lógica que kgNetoShare por muestra).
       */
      function buildKgDisponibleAgrupado() {
        const map = new Map();
        for (const row of rows) {
          if (row.procesado) continue;
          if (asNumber(row.total) <= 0) continue;
          const variedad = String(row.variedad ?? "").trim() || "—";
          const productor = String(row.productor ?? "").trim() || "—";
          const key = variedad + "\t" + productor;
          let g = map.get(key);
          if (!g) {
            g = {
              variedad,
              productor,
              muestras: 0,
              kgNetoTotal: 0,
              porCalibre: {}
            };
            for (const ck of CALIBRE_KEYS) g.porCalibre[ck] = 0;
            map.set(key, g);
          }
          g.muestras += 1;
          const netRaw = row.kilosNetoLote != null && Number.isFinite(Number(row.kilosNetoLote)) ? Number(row.kilosNetoLote) : 0;
          g.kgNetoTotal += netRaw;
          for (const ck of CALIBRE_KEYS) {
            const kg = kgNetoShare(row, row[ck]);
            if (kg != null) g.porCalibre[ck] += kg;
          }
        }
        const list = Array.from(map.values());
        list.sort((a, b) => {
          const v = a.variedad.localeCompare(b.variedad, "es");
          if (v !== 0) return v;
          return a.productor.localeCompare(b.productor, "es");
        });
        return list;
      }

      function renderKgCalibreModalContent() {
        const body = document.getElementById("kg-calibre-modal-body");
        if (!body) return;
        const grupos = buildKgDisponibleAgrupado();
        if (!grupos.length) {
          body.innerHTML =
            '<p class="kg-calibre-empty-msg">No hay muestras disponibles (no procesadas, con total de frutos mayor que cero). Cargue datos o desmarque «procesado» en muestras con clasificación.</p>';
          return;
        }
        const tot = {
          muestras: 0,
          kgNetoTotal: 0,
          porCalibre: {}
        };
        for (const ck of CALIBRE_KEYS) tot.porCalibre[ck] = 0;
        for (const g of grupos) {
          tot.muestras += g.muestras;
          tot.kgNetoTotal += g.kgNetoTotal;
          for (const ck of CALIBRE_KEYS) tot.porCalibre[ck] += g.porCalibre[ck];
        }
        const thCalibres = CALIBRE_AGG_LABELS.map((c) => "<th>" + c.label + " (kg)</th>").join("");
        let rowsHtml = "";
        for (const g of grupos) {
          const celdas = CALIBRE_KEYS.map((ck) => "<td>" + fmtKgDisponibleCell(g.porCalibre[ck]) + "</td>").join("");
          rowsHtml +=
            "<tr><td>" +
            escapeHtml(g.variedad) +
            "</td><td>" +
            escapeHtml(g.productor) +
            "</td><td>" +
            g.muestras +
            "</td><td>" +
            fmtKgDisponibleCell(g.kgNetoTotal) +
            "</td>" +
            celdas +
            "</tr>";
        }
        const footCalibres = CALIBRE_KEYS.map((ck) => "<td>" + fmtKgDisponibleCell(tot.porCalibre[ck]) + "</td>").join("");
        body.innerHTML =
          '<table class="kg-calibre-table"><thead><tr>' +
          "<th>Variedad</th><th>Productor</th><th>Muestras</th><th>Kg neto total</th>" +
          thCalibres +
          "</tr></thead><tbody>" +
          rowsHtml +
          "</tbody><tfoot><tr><td colspan=\"2\">Total</td><td>" +
          tot.muestras +
          "</td><td>" +
          fmtKgDisponibleCell(tot.kgNetoTotal) +
          "</td>" +
          footCalibres +
          "</tr></tfoot></table>";
      }

      function escapeHtml(s) {
        return String(s)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;");
      }

      let kgCalibrePrevBodyOverflow = "";

      function openKgCalibreModal() {
        renderKgCalibreModalContent();
        const modal = document.getElementById("kg-calibre-modal");
        if (!modal || modal.classList.contains("open")) return;
        kgCalibrePrevBodyOverflow = document.body.style.overflow;
        document.body.style.overflow = "hidden";
        modal.classList.add("open");
        modal.setAttribute("aria-hidden", "false");
      }

      function closeKgCalibreModal() {
        const modal = document.getElementById("kg-calibre-modal");
        if (!modal || !modal.classList.contains("open")) return;
        modal.classList.remove("open");
        modal.setAttribute("aria-hidden", "true");
        document.body.style.overflow = kgCalibrePrevBodyOverflow;
      }

      function formatPctWithKgNet(pctVal, row, shareNumerator) {
        const pctStr = formatPct(pctVal);
        const kg = kgNetoShare(row, shareNumerator);
        if (kg == null) return `${pctStr} (— kg)`;
        return `${pctStr} (${kg.toLocaleString("es-CL", { minimumFractionDigits: 0, maximumFractionDigits: 2 })} kg)`;
      }

      function calibreSubLabel(row, fieldKey) {
        const total = asNumber(row.total);
        const n = asNumber(row[fieldKey]);
        if (total <= 0) return "—";
        const p = pct(n, total);
        const kg = kgNetoShare(row, n);
        const pctStr = formatPct(p);
        if (kg == null) return `${pctStr} (— kg)`;
        return `${pctStr} (${kg.toLocaleString("es-CL", { minimumFractionDigits: 0, maximumFractionDigits: 2 })} kg)`;
      }

      function refreshRowCalcAndCalibre(rowIndex) {
        const tr = document.querySelector(`#samples-body tr[data-row-index="${rowIndex}"]`);
        if (!tr) return;
        const row = rows[rowIndex];
        if (!row) return;
        const calc = calculate(row);
        const cells = tr.querySelectorAll(".cell-calc");
        if (cells[0]) cells[0].textContent = formatPctWithKgNet(calc.defectPct, row, calc.defectos);
        if (cells[1]) cells[1].textContent = formatPctWithKgNet(calc.exportablePct, row, calc.exportable);
        if (cells[2]) cells[2].textContent = calc.promedioCalibre.toLocaleString("es-CL", { maximumFractionDigits: 1 });
        tr.querySelectorAll("input[data-calibre]").forEach((inp) => {
          const key = inp.getAttribute("data-calibre");
          const sub = inp.nextElementSibling;
          if (key && sub && sub.classList.contains("calibre-sub")) {
            sub.textContent = calibreSubLabel(row, key);
          }
        });
        tr.querySelectorAll("input[data-clasif]").forEach((inp) => {
          const key = inp.getAttribute("data-clasif");
          const sub = inp.nextElementSibling;
          if (key && sub && sub.classList.contains("calibre-sub")) {
            sub.textContent = calibreSubLabel(row, key);
          }
        });
      }

      function calculate(row) {
        const total = asNumber(row.total);
        const defectos = DEFECTO_KEYS.reduce((acc, k) => acc + asNumber(row[k]), 0);
        const zumo = sumZumo(row);
        const exportable = Math.max(0, total - zumo);
        const calibreTotal =
          asNumber(row.cPre) * 21 +
          asNumber(row.c22) * 23 +
          asNumber(row.c24) * 25 +
          asNumber(row.c26) * 27 +
          asNumber(row.c28) * 29 +
          asNumber(row.c30) * 31 +
          asNumber(row.c32) * 35;
        const calibreCount =
          asNumber(row.cPre) +
          asNumber(row.c22) +
          asNumber(row.c24) +
          asNumber(row.c26) +
          asNumber(row.c28) +
          asNumber(row.c30) +
          asNumber(row.c32);
        const defectPct = pct(defectos, total);
        const exportablePct = pct(exportable, total);
        const promedioCalibre = calibreCount ? calibreTotal / calibreCount : 0;
        const estado = asNumber(row.pudricion) > 0 || defectPct > 10 ? "critico" : defectPct > 5 ? "alerta" : "ok";

        return { defectos, defectPct, exportable, exportablePct, promedioCalibre, estado };
      }

      function visibleRows() {
        const search = searchInput.value.trim().toLowerCase();
        const status = statusFilter.value;
        return rows
          .map((row, index) => ({ row, index, calc: calculate(row) }))
          .filter(({ row, calc }) => {
            const haystack = `${row.fecha} ${row.lote} ${row.productor} ${row.variedad} ${row.bandasCamara ?? ""} ${row.kilosBrutoLote ?? ""} ${row.kilosNetoLote ?? ""} ${row.observaciones}`.toLowerCase();
            const matchSearch = !search || haystack.includes(search);
            const matchStatus = status === "todos" || calc.estado === status;
            return matchSearch && matchStatus;
          });
      }

      function buildCamaraGroups() {
        const map = new Map();
        for (const row of rows) {
          const lote = String(row.lote ?? "").trim();
          if (!lote) continue;
          const variedad = String(row.variedad ?? "").trim();
          const productor = String(row.productor ?? "").trim();
          const key = `${lote.toLowerCase()}\0${variedad.toLowerCase()}\0${productor.toLowerCase()}`;
          if (!map.has(key)) map.set(key, []);
          map.get(key).push(row);
        }
        const out = [];
        for (const [, arr] of map) {
          const bandasSet = new Set();
          let cajas = 0;
          let kilos = 0;
          let kilosNeto = 0;
          let frutos = 0;
          let procN = 0;
          const lote = String(arr[0].lote ?? "").trim();
          const variedad = String(arr[0].variedad ?? "").trim();
          const productor = String(arr[0].productor ?? "").trim();
          for (const row of arr) {
            const b = String(row.bandasCamara ?? "").trim();
            if (b) bandasSet.add(b);
            if (row.cantidadCajas != null && Number.isFinite(Number(row.cantidadCajas))) {
              cajas += Number(row.cantidadCajas);
            }
            if (row.kilosBrutoLote != null && Number.isFinite(Number(row.kilosBrutoLote))) {
              kilos += Number(row.kilosBrutoLote);
            }
            if (row.kilosNetoLote != null && Number.isFinite(Number(row.kilosNetoLote))) {
              kilosNeto += Number(row.kilosNetoLote);
            }
            frutos += asNumber(row.total);
            if (row.procesado) procN += 1;
          }

          const n = arr.length;
          let procLabel = "No";
          if (procN === n && n > 0) procLabel = "Sí";
          else if (procN > 0) procLabel = "Parcial";

          out.push({
            lote,
            variedad,
            productor,
            bandaText: bandasSet.size
              ? [...bandasSet].sort((a, b) => a.localeCompare(b, "es", { numeric: true })).join(" · ")
              : "—",
            cajas,
            kilos,
            kilosNeto,
            frutos,
            procLabel,
            n
          });
        }
        out.sort((a, b) => {
          const c = a.lote.localeCompare(b.lote, "es", { numeric: true });
          if (c !== 0) return c;
          const v = a.variedad.localeCompare(b.variedad, "es");
          if (v !== 0) return v;
          return a.productor.localeCompare(b.productor, "es");
        });
        return out;
      }

      function renderCamaraResumen() {
        const body = document.getElementById("camara-resumen-body");
        const empty = document.getElementById("camara-empty");
        const meta = document.getElementById("camara-panel-meta");
        if (!body || !empty || !meta) return;
        const groups = buildCamaraGroups();
        body.replaceChildren();
        if (!groups.length) {
          empty.hidden = false;
          empty.textContent =
            rows.length === 0
              ? "Aún no hay muestras cargadas."
              : "Ningún registro tiene código de lote; informa el lote para ver totales por lote, variedad y productor.";
          meta.textContent = "";
          return;
        }
        empty.hidden = true;
        meta.textContent = `${groups.length} grupo${groups.length === 1 ? "" : "s"} (lote + variedad + productor)`;

        for (const g of groups) {
          const tr = document.createElement("tr");
          const cells = [
            { text: g.lote, className: "camara-lote" },
            { text: g.variedad || "—", className: "" },
            { text: g.productor || "—", className: "" },
            { text: g.bandaText, className: "camara-banda" },
            {
              text: g.cajas ? g.cajas.toLocaleString("es-CL") : "—",
              className: ""
            },
            {
              text: g.kilos
                ? g.kilos.toLocaleString("es-CL", { minimumFractionDigits: 0, maximumFractionDigits: 2 })
                : "—",
              className: ""
            },
            {
              text: g.kilosNeto
                ? g.kilosNeto.toLocaleString("es-CL", { minimumFractionDigits: 0, maximumFractionDigits: 2 })
                : "—",
              className: ""
            },
            { text: g.frutos ? g.frutos.toLocaleString("es-CL") : "0", className: "" },
            { text: g.procLabel, className: "" }
          ];
          for (const c of cells) {
            const td = document.createElement("td");
            if (c.className) td.className = c.className;
            td.textContent = c.text;
            tr.appendChild(td);
          }
          body.appendChild(tr);
        }
      }

      function createTextInput(row, index, field, type = "text") {
        const input = document.createElement("input");
        input.type = type;
        input.value = row[field] ?? "";
        input.addEventListener("input", () => {
          rows[index][field] = input.value;
          scheduleUpdate(index, field, input.value);
          updateMetrics();
        });
        if (field === "fecha") {
          input.addEventListener("blur", () => {
            if (tableSortMode === "fecha") {
              applyTableSort();
              render();
            }
          });
        }
        return input;
      }

      function createNumberInput(row, index, field, step = "1") {
        const input = document.createElement("input");
        input.type = "number";
        input.min = "0";
        input.step = step;
        input.value = asNumber(row[field]);
        if (CALIBRE_KEYS.includes(field)) {
          input.setAttribute("data-calibre", field);
        }
        input.addEventListener("input", () => {
          const v = asNumber(input.value);
          rows[index][field] = v;
          scheduleUpdate(index, field, v);
          if (!CALIBRE_KEYS.includes(field)) {
            renderCalcCells(input, index);
          }
          updateMetrics();
        });
        return input;
      }

      function sumFromPlusExpression(raw) {
        const s = String(raw ?? "").trim();
        if (!s) return null;
        const parts = s.split("+").map((p) => p.trim().replace(",", ".")).filter(Boolean);
        if (!parts.length) return null;
        let sum = 0;
        let any = false;
        for (const p of parts) {
          const n = Number(p);
          if (Number.isFinite(n)) {
            sum += n;
            any = true;
          }
        }
        return any ? sum : null;
      }

      function createSumParseInput(row, index, field, decimals) {
        const input = document.createElement("input");
        input.type = "text";
        input.inputMode = "decimal";
        input.className = "input-sum";
        input.placeholder = decimals === 0 ? "25+50" : "1200+800";
        input.title = "Varios pallets: escribe sumas con + (ej. 25+50). Enter o salir de la celda para guardar el total.";

        const fmt = (n) =>
          decimals === 0
            ? String(Math.round(n))
            : (Math.round(n * 100) / 100).toLocaleString("es-CL", {
                minimumFractionDigits: 0,
                maximumFractionDigits: 2
              });

        const syncDisplay = () => {
          const v = row[field];
          input.value = v != null && Number.isFinite(Number(v)) ? fmt(Number(v)) : "";
        };
        syncDisplay();

        const commit = () => {
          const trimmed = String(input.value).trim();
          if (!trimmed) {
            rows[index][field] = null;
            input.value = "";
            scheduleUpdate(index, field, null);
            updateMetrics();
            if (field === "kilosNetoLote") refreshRowCalcAndCalibre(index);
            return;
          }
          const sum = sumFromPlusExpression(trimmed);
          if (sum == null) {
            syncDisplay();
            return;
          }
          const rounded = decimals === 0 ? Math.round(sum) : Math.round(sum * 100) / 100;
          rows[index][field] = rounded;
          input.value = fmt(rounded);
          scheduleUpdate(index, field, rounded);
          updateMetrics();
          if (field === "kilosNetoLote") refreshRowCalcAndCalibre(index);
        };
        input.addEventListener("blur", commit);
        input.addEventListener("keydown", (e) => {
          if (e.key === "Enter") {
            e.preventDefault();
            commit();
            input.blur();
          }
        });
        return input;
      }

      function renderCalcCells(originInput, index) {
        refreshRowCalcAndCalibre(index);
      }

      function createCalcCell(value) {
        const td = document.createElement("td");
        const span = document.createElement("span");
        span.className = "cell-calc";
        span.textContent = value;
        td.appendChild(span);
        return td;
      }

      function createEtiquetaCell(row) {
        const td = document.createElement("td");
        td.className = "img-cell";
        if (row.etiquetaPallet) {
          const thumb = document.createElement("div");
          thumb.className = "img-thumb";
          thumb.title = `Etiqueta del lote ${row.lote || ""}`;
          const img = document.createElement("img");
          img.src = row.etiquetaPallet;
          img.alt = "Etiqueta del pallet";
          thumb.appendChild(img);
          thumb.addEventListener("click", () => {
            openLightbox([row.etiquetaPallet], 0, `Etiqueta · Lote ${row.lote || "—"}`);
          });
          td.appendChild(thumb);
        } else {
          const empty = document.createElement("span");
          empty.className = "img-empty";
          empty.textContent = "—";
          td.appendChild(empty);
        }
        return td;
      }

      function createFotosCell(row) {
        const td = document.createElement("td");
        td.className = "img-cell";
        const fotos = Array.isArray(row.fotosDefectos) ? row.fotosDefectos : [];
        if (fotos.length) {
          const thumb = document.createElement("div");
          thumb.className = "img-thumb";
          thumb.title = `${fotos.length} foto${fotos.length === 1 ? "" : "s"} de defectos`;
          const img = document.createElement("img");
          img.src = fotos[0];
          img.alt = "Foto de defectos";
          thumb.appendChild(img);
          if (fotos.length > 1) {
            const count = document.createElement("span");
            count.className = "count";
            count.textContent = `+${fotos.length - 1}`;
            thumb.appendChild(count);
          }
          thumb.addEventListener("click", () => {
            openLightbox(fotos, 0, `Defectos · Lote ${row.lote || "—"}`);
          });
          td.appendChild(thumb);
        } else {
          const empty = document.createElement("span");
          empty.className = "img-empty";
          empty.textContent = "—";
          td.appendChild(empty);
        }
        return td;
      }

      function render() {
        tbody.replaceChildren();
        const items = visibleRows();

        if (!items.length) {
          emptyState.hidden = false;
        } else {
          emptyState.hidden = true;
        }

        items.forEach(({ row, index, calc }) => {
          const tr = document.createElement("tr");
          tr.dataset.rowIndex = String(index);

          const checkTd = document.createElement("td");
          const checkWrap = document.createElement("div");
          checkWrap.className = "cell-check";
          const cb = document.createElement("input");
          cb.type = "checkbox";
          cb.checked = !!row.procesado;
          cb.title = "Marcar cuando ya está procesado";
          cb.addEventListener("change", () => {
            rows[index].procesado = cb.checked;
            scheduleUpdate(index, "procesado", cb.checked);
            updateMetrics();
          });
          checkWrap.appendChild(cb);
          checkTd.appendChild(checkWrap);
          tr.appendChild(checkTd);

          const bandaTd = document.createElement("td");
          const bandaInput = document.createElement("input");
          bandaInput.type = "text";
          bandaInput.className = "input-banda-map";
          bandaInput.readOnly = true;
          bandaInput.value = row.bandasCamara ?? "";
          bandaInput.placeholder = row.procesado ? "Procesado" : "Clic → mapa…";
          bandaInput.title = row.procesado
            ? "No se puede editar en cámara mientras esté procesado."
            : "Clic: mapa B1…B12; B1 máx. 3 posiciones en P (puerta al final de B1). P1 fondo; puede elegir cualquier celda libre.";
          bandaInput.disabled = !!row.procesado;
          bandaInput.addEventListener("click", () => {
            if (row.procesado) return;
            openCamaraModal(index);
          });
          bandaTd.appendChild(bandaInput);
          tr.appendChild(bandaTd);

          idColumns.forEach((col) => {
            const td = document.createElement("td");
            td.appendChild(createTextInput(row, index, col.key, col.type));
            tr.appendChild(td);
          });

          const cajasTd = document.createElement("td");
          cajasTd.appendChild(createSumParseInput(row, index, "cantidadCajas", 0));
          tr.appendChild(cajasTd);

          const kilosTd = document.createElement("td");
          kilosTd.appendChild(createSumParseInput(row, index, "kilosBrutoLote", 2));
          tr.appendChild(kilosTd);

          const kilosNetoTd = document.createElement("td");
          kilosNetoTd.appendChild(createSumParseInput(row, index, "kilosNetoLote", 2));
          tr.appendChild(kilosNetoTd);

          row.total = sumCalibres(row);
          const totalTd = document.createElement("td");
          const totalInput = document.createElement("input");
          totalInput.type = "number";
          totalInput.className = "total-readonly";
          totalInput.readOnly = true;
          totalInput.tabIndex = -1;
          totalInput.value = String(row.total);
          totalTd.appendChild(totalInput);
          tr.appendChild(totalTd);

          row.zumo = sumZumo(row);
          row.segunda = sumSegunda(row);
          row.primera = sumPrimera(row);

          let primeraInput, segundaInput, zumoInput;

          const refreshClasif = () => {
            const r = rows[index];
            const newZumo = sumZumo(r);
            const newSegunda = sumSegunda(r);
            const newPrimera = sumPrimera(r);
            r.zumo = newZumo;
            r.segunda = newSegunda;
            r.primera = newPrimera;
            if (primeraInput) primeraInput.value = String(newPrimera);
            if (segundaInput) segundaInput.value = String(newSegunda);
            if (zumoInput) zumoInput.value = String(newZumo);
            scheduleUpdate(index, "primera", newPrimera);
            scheduleUpdate(index, "segunda", newSegunda);
            scheduleUpdate(index, "zumo", newZumo);
            refreshRowCalcAndCalibre(index);
          };

          numberFields.forEach((field) => {
            const td = document.createElement("td");
            if (CALIBRE_KEYS.includes(field)) {
              const wrap = document.createElement("div");
              wrap.className = "calibre-cell-wrap";
              const input = createNumberInput(row, index, field);
              const sub = document.createElement("span");
              sub.className = "calibre-sub";
              sub.textContent = calibreSubLabel(row, field);
              wrap.appendChild(input);
              wrap.appendChild(sub);
              td.appendChild(wrap);
              input.addEventListener("input", () => {
                const newTotal = sumCalibres(rows[index]);
                rows[index].total = newTotal;
                totalInput.value = String(newTotal);
                scheduleUpdate(index, "total", newTotal);
                refreshClasif();
              });
            } else {
              const input = createNumberInput(row, index, field);
              if (DEFECTO_KEYS.includes(field)) {
                input.addEventListener("input", refreshClasif);
              }
              td.appendChild(input);
            }
            tr.appendChild(td);
          });

          const buildClasifCell = (fieldKey, initialValue) => {
            const td = document.createElement("td");
            const wrap = document.createElement("div");
            wrap.className = "calibre-cell-wrap";
            const input = document.createElement("input");
            input.type = "number";
            input.className = "total-readonly";
            input.readOnly = true;
            input.tabIndex = -1;
            input.setAttribute("data-clasif", fieldKey);
            input.value = String(initialValue);
            const sub = document.createElement("span");
            sub.className = "calibre-sub";
            sub.textContent = calibreSubLabel(row, fieldKey);
            wrap.appendChild(input);
            wrap.appendChild(sub);
            td.appendChild(wrap);
            return { td, input, sub };
          };

          const primeraCell = buildClasifCell("primera", row.primera);
          primeraInput = primeraCell.input;
          tr.appendChild(primeraCell.td);

          const segundaCell = buildClasifCell("segunda", row.segunda);
          segundaInput = segundaCell.input;
          tr.appendChild(segundaCell.td);

          const zumoCell = buildClasifCell("zumo", row.zumo);
          zumoInput = zumoCell.input;
          tr.appendChild(zumoCell.td);

          tr.appendChild(createCalcCell(formatPctWithKgNet(calc.defectPct, row, calc.defectos)));
          tr.appendChild(createCalcCell(formatPctWithKgNet(calc.exportablePct, row, calc.exportable)));
          tr.appendChild(createCalcCell(calc.promedioCalibre.toLocaleString("es-CL", { maximumFractionDigits: 1 })));

          const notesTd = document.createElement("td");
          const notes = document.createElement("textarea");
          notes.rows = 1;
          notes.value = row.observaciones ?? "";
          notes.addEventListener("input", () => {
            rows[index].observaciones = notes.value;
            scheduleUpdate(index, "observaciones", notes.value);
          });
          notesTd.appendChild(notes);
          tr.appendChild(notesTd);

          tr.appendChild(createEtiquetaCell(row));
          tr.appendChild(createFotosCell(row));

          const actionTd = document.createElement("td");
          const removeButton = document.createElement("button");
          removeButton.type = "button";
          removeButton.className = "icon-btn";
          removeButton.title = "Eliminar muestra";
          removeButton.setAttribute("aria-label", "Eliminar muestra");
          removeButton.textContent = "×";
          removeButton.addEventListener("click", () => {
            if (!confirm("¿Eliminar esta muestra?")) return;
            deleteRow(index);
          });
          actionTd.appendChild(removeButton);
          tr.appendChild(actionTd);

          tbody.appendChild(tr);
        });
        updateMetrics();
      }

      function updateMetrics() {
        const items = visibleRows();
        const totals = items.reduce(
          (acc, { row, calc }) => {
            acc.samples += 1;
            acc.fruits += asNumber(row.total);
            acc.exportable += calc.exportable;
            acc.defects += calc.defectos;
            return acc;
          },
          { samples: 0, fruits: 0, exportable: 0, defects: 0 }
        );

        document.getElementById("metric-samples").textContent = String(totals.samples);
        document.getElementById("metric-fruits").textContent = totals.fruits.toLocaleString("es-CL");
        let kgExpSum = 0;
        let kgDefSum = 0;
        let kgExpN = 0;
        let kgDefN = 0;
        for (const { row, calc } of items) {
          const ke = kgNetoShare(row, calc.exportable);
          const kd = kgNetoShare(row, calc.defectos);
          if (ke != null) {
            kgExpSum += ke;
            kgExpN += 1;
          }
          if (kd != null) {
            kgDefSum += kd;
            kgDefN += 1;
          }
        }
        const expPctStr = formatPct(pct(totals.exportable, totals.fruits));
        const defPctStr = formatPct(pct(totals.defects, totals.fruits));
        document.getElementById("metric-exportable").textContent =
          kgExpN > 0
            ? `${expPctStr} (${kgExpSum.toLocaleString("es-CL", { minimumFractionDigits: 0, maximumFractionDigits: 2 })} kg)`
            : `${expPctStr} (— kg)`;
        document.getElementById("metric-defects").textContent =
          kgDefN > 0
            ? `${defPctStr} (${kgDefSum.toLocaleString("es-CL", { minimumFractionDigits: 0, maximumFractionDigits: 2 })} kg)`
            : `${defPctStr} (— kg)`;
        renderCamaraResumen();
        renderFridgeMap();
      }

      function buildMapRowsPayload() {
        return rows
          .filter((r) => !r.procesado)
          .map((r) => ({
            id: r.id,
            procesado: false,
            lote: r.lote,
            variedad: r.variedad,
            productor: r.productor,
            camara_banda: r.camaraBanda,
            camara_posicion: r.camaraPosicion,
            camara_altura: r.camaraAltura,
            bandas_camara: r.bandasCamara
          }));
      }

      function setCamaraModalError(msg) {
        const el = document.getElementById("camara-modal-error");
        if (!el) return;
        if (!msg) {
          el.textContent = "";
          el.hidden = true;
          return;
        }
        el.textContent = msg;
        el.hidden = false;
      }

      let laTorreNoticeTimer = 0;
      function showLaTorreNotice(msg) {
        const el = document.getElementById("la-torre-notice");
        if (!el) return;
        el.textContent = msg;
        el.hidden = false;
        if (laTorreNoticeTimer) window.clearTimeout(laTorreNoticeTimer);
        laTorreNoticeTimer = window.setTimeout(() => {
          el.hidden = true;
          el.textContent = "";
          laTorreNoticeTimer = 0;
        }, 8000);
      }

      /** @param {{ code: string; b: number; p: number; h?: number } | null} det */
      function formatCamaraInvalidity(det, M) {
        if (!det) return "La selección ya no es válida. Revise celdas ocupadas o duplicadas en el mapa.";
        const b = Number(det.b);
        const p = Number(det.p);
        const h = Number(det.h != null ? det.h : 1);
        const sk = M.slotKey(b, p, h);
        switch (det.code) {
          case "vacio":
            return "Seleccione al menos una celda en el mapa.";
          case "dup":
            return "Hay celdas repetidas en la selección (" + sk + "). Pulse de nuevo una celda elegida para quitarla.";
          case "layout":
            return "La celda " + sk + " queda fuera del plano de cámara.";
          case "ocupada":
            return "La celda " + sk + " está ocupada por otro lote. Quite la selección que la solape o elija otra coordenada.";
          case "profundidad": {
            if (b <= 1) {
              return "En la banda B" + p + " no puede usarse " + sk + " sin cumplir la regla de profundidad (fondo → puerta).";
            }
            const need = M.slotKey(b - 1, p, 1);
            return (
              "En la banda B" +
              p +
              " debe ocuparse antes " +
              need +
              " (más al fondo) antes de elegir " +
              sk +
              "."
            );
          }
          case "h2":
            return "Para altura H2 en " + sk + " debe haber un pallet en H1 en esa misma posición de planta.";
          default:
            return "No se puede usar la celda " + sk + ".";
        }
      }

      function renderFridgeMap() {
        const panel = document.getElementById("fridge-map-panel");
        if (panel && panel.classList.contains("is-collapsed")) return;
        const root = document.getElementById("fridge-map-root");
        if (!root || !window.LaTorreCamaraMap) return;
        window.LaTorreCamaraMap.render(root, buildMapRowsPayload(), { mode: "view" });
      }

      /** Al abrir el modal: había al menos una celda en mapa / texto bandas (sirve para habilitar «Guardar» al vaciar todo). */
      let camaraModalInitialHadPosition = false;

      function syncCamaraModalConfirmEnabled() {
        const confirmBtn = document.getElementById("camara-modal-confirm");
        if (!confirmBtn) return;
        const canSaveEmpty = camaraModalInitialHadPosition && camaraModalDraftSlots.length === 0;
        confirmBtn.disabled = camaraModalDraftSlots.length === 0 && !canSaveEmpty;
      }

      function clearCamaraModalSelection() {
        camaraModalDraftSlots = [];
        setCamaraModalError("");
        const draftEl = document.getElementById("camara-modal-draft");
        const M = window.LaTorreCamaraMap;
        if (draftEl && M) {
          draftEl.textContent = camaraModalInitialHadPosition
            ? "Selección vacía. Pulse «Guardar posición» para quitar la ubicación en cámara de esta muestra, o elija celdas de nuevo."
            : "Sin celdas seleccionadas. Elija al menos una posición (varias si el lote está repartido).";
        }
        syncCamaraModalConfirmEnabled();
        renderCamaraModalMap();
      }

      /** Id de muestra (`rows[].id`) cuyo mapa está abierto; no usar índice (cambia al ordenar la tabla). */
      let camaraModalRowId = null;
      /** @type {{ b: number; p: number; h: number }[]} */
      let camaraModalDraftSlots = [];

      function renderCamaraModalMap() {
        const root = document.getElementById("camara-modal-map-root");
        if (!root || !window.LaTorreCamaraMap || camaraModalRowId == null) return;
        const idx = rowIndexById(camaraModalRowId);
        const row = idx >= 0 ? rows[idx] : null;
        if (!row) return;
        const excludeId = row.id;
        const M = window.LaTorreCamaraMap;
        M.render(root, buildMapRowsPayload(), {
          mode: "pick",
          excludeId,
          multiSelect: true,
          selection: camaraModalDraftSlots,
          editingDraftSlots: camaraModalDraftSlots,
          onSlotClick: (c) => {
            if (c.toggle) {
              camaraModalDraftSlots = camaraModalDraftSlots.filter(
                (s) => !M.slotsEqual(s, { b: c.b, p: c.p, h: c.h })
              );
              setCamaraModalError("");
            } else {
              const next = camaraModalDraftSlots.concat([{ b: c.b, p: c.p, h: c.h }]);
              if (!M.validateDraftSlots(buildMapRowsPayload(), excludeId, next)) {
                const det = M.explainDraftInvalidity(buildMapRowsPayload(), excludeId, next);
                setCamaraModalError(formatCamaraInvalidity(det, M));
                return;
              }
              camaraModalDraftSlots = next;
              setCamaraModalError("");
            }
            const draftEl = document.getElementById("camara-modal-draft");
            if (draftEl) {
              draftEl.textContent = camaraModalDraftSlots.length
                ? "Selección: " +
                  M.encodeSlotsText(camaraModalDraftSlots) +
                  " · Pulse «Guardar posición» para aplicar."
                : camaraModalInitialHadPosition
                  ? "Selección vacía. Pulse «Guardar posición» para quitar la ubicación en cámara, o elija celdas de nuevo."
                  : "Sin celdas seleccionadas. Elija al menos una posición (varias si el lote está repartido).";
            }
            syncCamaraModalConfirmEnabled();
            renderCamaraModalMap();
          }
        });
      }

      function openCamaraModal(rowIndex) {
        const row = rows[rowIndex];
        if (!row || !window.LaTorreCamaraMap) return;
        if (row.procesado) {
          showLaTorreNotice(
            "No se puede cambiar la posición en cámara mientras la muestra esté marcada como procesada."
          );
          return;
        }
        if (row.id == null) {
          showLaTorreNotice("La muestra aún no tiene id de base de datos; recargue la página.");
          return;
        }
        setCamaraModalError("");
        camaraModalRowId = row.id;
        camaraModalDraftSlots = (window.LaTorreCamaraMap.parseAllSlotsFromRow(row) || []).map((s) => ({
          b: s.b,
          p: s.p,
          h: s.h
        }));
        camaraModalInitialHadPosition = camaraModalDraftSlots.length > 0;
        const sub = document.getElementById("camara-modal-subtitle");
        if (sub) {
          sub.textContent = [row.lote && `Lote ${row.lote}`, row.variedad, row.productor].filter(Boolean).join(" · ");
        }
        const draftEl = document.getElementById("camara-modal-draft");
        const M = window.LaTorreCamaraMap;
        if (draftEl) {
          draftEl.textContent = camaraModalDraftSlots.length
            ? "Actual: " +
              M.encodeSlotsText(camaraModalDraftSlots) +
              " · Pulse celdas para añadir o quitar; «Guardar posición» aplica."
            : "Sin posición en mapa. B1: solo P1–P3. Puerta al final de B1. Elija cualquier celda libre; varias si el lote está en más de un sitio.";
        }
        const confirmBtn = document.getElementById("camara-modal-confirm");
        syncCamaraModalConfirmEnabled();
        const modal = document.getElementById("camara-modal");
        if (modal) {
          modal.classList.add("open");
          modal.setAttribute("aria-hidden", "false");
        }
        renderCamaraModalMap();
      }

      function closeCamaraModal() {
        setCamaraModalError("");
        camaraModalRowId = null;
        camaraModalDraftSlots = [];
        const modal = document.getElementById("camara-modal");
        if (modal) {
          modal.classList.remove("open");
          modal.setAttribute("aria-hidden", "true");
        }
      }

      async function confirmCamaraModal() {
        if (camaraModalRowId == null || !window.LaTorreCamaraMap) return;
        const idx = rowIndexById(camaraModalRowId);
        if (idx < 0) {
          showLaTorreNotice(
            "No se encontró la muestra en la tabla (quizá se reordenó o actualizó). Cierre el modal y vuelva a abrir desde la fila correcta."
          );
          closeCamaraModal();
          return;
        }
        const row = rows[idx];
        const M = window.LaTorreCamaraMap;

        const prev = {
          camaraBanda: row.camaraBanda,
          camaraPosicion: row.camaraPosicion,
          camaraAltura: row.camaraAltura,
          bandasCamara: row.bandasCamara
        };
        const confirmBtn = document.getElementById("camara-modal-confirm");
        if (confirmBtn) confirmBtn.disabled = true;

        if (!camaraModalDraftSlots.length) {
          if (!camaraModalInitialHadPosition) {
            if (confirmBtn) confirmBtn.disabled = false;
            closeCamaraModal();
            render();
            return;
          }
          if (
            !confirm(
              "¿Quitar por completo la posición en cámara de esta muestra? Se actualizará la base de datos."
            )
          ) {
            if (confirmBtn) syncCamaraModalConfirmEnabled();
            return;
          }
          row.camaraBanda = null;
          row.camaraPosicion = null;
          row.camaraAltura = 1;
          row.bandasCamara = "";
          scheduleUpdate(idx, "camaraBanda", null);
          scheduleUpdate(idx, "camaraPosicion", null);
          scheduleUpdate(idx, "camaraAltura", 1);
          scheduleUpdate(idx, "bandasCamara", null);
        } else {
          const slots = camaraModalDraftSlots.map((s) => ({ b: s.b, p: s.p, h: s.h }));
          if (!M.validateDraftSlots(buildMapRowsPayload(), row.id, slots)) {
            const det = M.explainDraftInvalidity(buildMapRowsPayload(), row.id, slots);
            setCamaraModalError(formatCamaraInvalidity(det, M));
            if (confirmBtn) confirmBtn.disabled = false;
            renderCamaraModalMap();
            return;
          }
          const enc = M.encodeSlotsText(slots);
          if (slots.length === 1) {
            const c = slots[0];
            const hN = Number(c.h);
            const hSlot = Number.isFinite(hN) && hN >= 1 ? hN : 1;
            row.camaraBanda = c.b;
            row.camaraPosicion = c.p;
            row.camaraAltura = hSlot;
            row.bandasCamara = enc;
            scheduleUpdate(idx, "camaraBanda", c.b);
            scheduleUpdate(idx, "camaraPosicion", c.p);
            scheduleUpdate(idx, "camaraAltura", hSlot);
            scheduleUpdate(idx, "bandasCamara", enc);
          } else {
            row.camaraBanda = null;
            row.camaraPosicion = null;
            /** Sin coordenada estructurada: BD puede tener NOT NULL en camara_altura; 1 es convención (solo bandas_camara). */
            row.camaraAltura = 1;
            row.bandasCamara = enc;
            scheduleUpdate(idx, "camaraBanda", null);
            scheduleUpdate(idx, "camaraPosicion", null);
            scheduleUpdate(idx, "camaraAltura", 1);
            scheduleUpdate(idx, "bandasCamara", enc);
          }
        }

        const flush = await flushAllPendingPatches();
        if (!flush.ok) {
          row.camaraBanda = prev.camaraBanda;
          row.camaraPosicion = prev.camaraPosicion;
          row.camaraAltura = prev.camaraAltura;
          row.bandasCamara = prev.bandasCamara;
          pendingPatches.delete(row.id);
          const t = debounceTimers.get(row.id);
          if (t) clearTimeout(t);
          debounceTimers.delete(row.id);
          const msg = flush.error?.message || String(flush.error ?? "");
          showLaTorreNotice(
            msg
              ? "No se pudo guardar la posición en el servidor: " + msg
              : "No se pudo guardar la posición en el servidor. Compruebe la conexión o que la migración SQL de cámara esté aplicada en Supabase."
          );
          if (confirmBtn) confirmBtn.disabled = false;
          renderCamaraModalMap();
          render();
          return;
        }

        closeCamaraModal();
        render();
      }

      function printFridgeMap() {
        const stamp = document.getElementById("map-print-stamp");
        const fridgePanel = document.getElementById("fridge-map-panel");
        const wasCollapsed = fridgePanel?.classList.contains("is-collapsed") ?? false;
        if (wasCollapsed) fridgePanel.classList.remove("is-collapsed");
        if (stamp) {
          stamp.textContent =
            "Impreso: " +
            new Date().toLocaleString("es-CL", { dateStyle: "short", timeStyle: "short" }) +
            " · Solo pallets en cámara (no procesados)";
        }
        renderFridgeMap();
        const onAfter = () => {
          document.body.classList.remove("printing-fridge-map");
          if (stamp) stamp.textContent = "";
          if (wasCollapsed) fridgePanel?.classList.add("is-collapsed");
          window.removeEventListener("afterprint", onAfter);
        };
        document.body.classList.add("printing-fridge-map");
        window.addEventListener("afterprint", onAfter);
        requestAnimationFrame(() => {
          window.print();
        });
      }

      function exportExcel() {
        const headers = [
          "Procesado", "Banda cámara (ej. 1(1))", "Fecha", "Lote", "Productor", "Variedad", "Cajas", "Kilos bruto", "Kilos neto",
          "Total Frutos", "P/C", "22-24", "24-26", "26-28", "28-30", "30-32", "+34",
          "Blanda", "Pitting", "Doble", "Deshidratada", "Partida", "Pudrición", "Falta de color", "Media luna", "Sin pedicelo", "Negro",
          "Primera (premium)", "Segunda (comercial)", "Zumo (desecho)",
          "% Defectos (kg neto)", "% Exportable (kg neto)", "Promedio Calibre", "Observaciones"
        ];

        const data = visibleRows().map(({ row, calc }) => [
          row.procesado ? "Sí" : "No",
          row.bandasCamara ?? "",
          row.fecha, row.lote, row.productor, row.variedad,
          row.cantidadCajas != null ? row.cantidadCajas : "",
          row.kilosBrutoLote != null ? row.kilosBrutoLote : "",
          row.kilosNetoLote != null ? row.kilosNetoLote : "",
          row.total,
          `${asNumber(row.cPre)} — ${calibreSubLabel(row, "cPre")}`,
          `${asNumber(row.c22)} — ${calibreSubLabel(row, "c22")}`,
          `${asNumber(row.c24)} — ${calibreSubLabel(row, "c24")}`,
          `${asNumber(row.c26)} — ${calibreSubLabel(row, "c26")}`,
          `${asNumber(row.c28)} — ${calibreSubLabel(row, "c28")}`,
          `${asNumber(row.c30)} — ${calibreSubLabel(row, "c30")}`,
          `${asNumber(row.c32)} — ${calibreSubLabel(row, "c32")}`,
          row.blanda, row.pitting, row.doble, row.deshidratada, row.partida, row.pudricion, row.colorBajo,
          asNumber(row.mediaLuna), asNumber(row.sinPedicelo), asNumber(row.negro),
          `${asNumber(row.primera)} — ${calibreSubLabel(row, "primera")}`,
          `${asNumber(row.segunda)} — ${calibreSubLabel(row, "segunda")}`,
          `${asNumber(row.zumo)} — ${calibreSubLabel(row, "zumo")}`,
          formatPctWithKgNet(calc.defectPct, row, calc.defectos),
          formatPctWithKgNet(calc.exportablePct, row, calc.exportable),
          calc.promedioCalibre.toLocaleString("es-CL", { maximumFractionDigits: 1 }),
          row.observaciones
        ]);

        const escape = (cell) =>
          String(cell ?? "")
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;");

        const htmlRows = [headers, ...data]
          .map((cells, rowIndex) => {
            const tag = rowIndex === 0 ? "th" : "td";
            return `<tr>${cells.map((cell) => `<${tag}>${escape(cell)}</${tag}>`).join("")}</tr>`;
          })
          .join("");

        const html = `<html><head><meta charset="UTF-8"><style>
          table { border-collapse: collapse; font-family: Aptos, Arial, sans-serif; }
          th { background: #9f1239; color: white; font-weight: 700; }
          th, td { border: 1px solid #d6d3d1; padding: 8px 10px; }
        </style></head><body><table>${htmlRows}</table></body></html>`;

        const blob = new Blob([html], { type: "application/vnd.ms-excel;charset=utf-8" });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;
        link.download = `la-torre-2026-muestras-${new Date().toISOString().slice(0, 10)}.xls`;
        document.body.appendChild(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(url);
      }

      document.getElementById("export-excel").addEventListener("click", exportExcel);
      const printMapBtn = document.getElementById("btn-print-fridge-map");
      if (printMapBtn) printMapBtn.addEventListener("click", printFridgeMap);
      const fridgePanel = document.getElementById("fridge-map-panel");
      const toggleFridgeBtn = document.getElementById("btn-toggle-fridge-map");
      if (toggleFridgeBtn && fridgePanel) {
        toggleFridgeBtn.addEventListener("click", () => {
          const collapsed = fridgePanel.classList.toggle("is-collapsed");
          toggleFridgeBtn.setAttribute("aria-expanded", collapsed ? "false" : "true");
          toggleFridgeBtn.textContent = collapsed ? "Mostrar mapa" : "Minimizar mapa";
          if (!collapsed) renderFridgeMap();
        });
      }
      document.getElementById("btn-kg-calibre-disponible")?.addEventListener("click", openKgCalibreModal);
      document.getElementById("kg-calibre-modal-close")?.addEventListener("click", closeKgCalibreModal);
      document.getElementById("kg-calibre-modal-cerrar")?.addEventListener("click", closeKgCalibreModal);
      document.getElementById("camara-modal-close")?.addEventListener("click", closeCamaraModal);
      document.getElementById("camara-modal-cancel")?.addEventListener("click", closeCamaraModal);
      document.getElementById("camara-modal-backdrop")?.addEventListener("click", closeCamaraModal);
      document.getElementById("camara-modal-clear-selection")?.addEventListener("click", clearCamaraModalSelection);
      document.getElementById("camara-modal-confirm")?.addEventListener("click", () => {
        void confirmCamaraModal();
      });
      searchInput.addEventListener("input", render);
      statusFilter.addEventListener("change", render);

      const lightbox = document.getElementById("lightbox");
      const lightboxImg = document.getElementById("lightbox-img");
      const lightboxInfo = document.getElementById("lightbox-info");
      const lightboxPrev = document.getElementById("lightbox-prev");
      const lightboxNext = document.getElementById("lightbox-next");
      let lightboxImages = [];
      let lightboxIndex = 0;
      let lightboxLabel = "";

      function openLightbox(images, startIndex, label) {
        lightboxImages = images;
        lightboxIndex = startIndex;
        lightboxLabel = label;
        showLightboxAt(startIndex);
        lightbox.classList.add("open");
        lightbox.setAttribute("aria-hidden", "false");
      }

      function showLightboxAt(i) {
        if (!lightboxImages.length) return;
        const idx = (i + lightboxImages.length) % lightboxImages.length;
        lightboxIndex = idx;
        lightboxImg.src = lightboxImages[idx];
        const counter = lightboxImages.length > 1 ? ` · ${idx + 1}/${lightboxImages.length}` : "";
        lightboxInfo.textContent = `${lightboxLabel}${counter}`;
        lightboxPrev.disabled = lightboxImages.length <= 1;
        lightboxNext.disabled = lightboxImages.length <= 1;
      }

      function closeLightbox() {
        lightbox.classList.remove("open");
        lightbox.setAttribute("aria-hidden", "true");
        lightboxImg.removeAttribute("src");
        lightboxImages = [];
      }

      document.getElementById("lightbox-close").addEventListener("click", closeLightbox);
      lightbox.addEventListener("click", (e) => {
        if (e.target === lightbox) closeLightbox();
      });
      lightboxPrev.addEventListener("click", () => showLightboxAt(lightboxIndex - 1));
      lightboxNext.addEventListener("click", () => showLightboxAt(lightboxIndex + 1));
      document.addEventListener("keydown", (e) => {
        const kgModal = document.getElementById("kg-calibre-modal");
        if (kgModal && kgModal.classList.contains("open")) {
          if (e.key === "Escape") {
            e.preventDefault();
            closeKgCalibreModal();
          }
          return;
        }
        const camModal = document.getElementById("camara-modal");
        if (camModal && camModal.classList.contains("open")) {
          if (e.key === "Escape") {
            e.preventDefault();
            closeCamaraModal();
          }
          return;
        }
        if (!lightbox.classList.contains("open")) return;
        if (e.key === "Escape") closeLightbox();
        if (e.key === "ArrowLeft") showLightboxAt(lightboxIndex - 1);
        if (e.key === "ArrowRight") showLightboxAt(lightboxIndex + 1);
      });

      window.addEventListener("focus", () => {
        void flushAllPendingPatches();
      });
      document.addEventListener("visibilitychange", () => {
        if (document.visibilityState === "hidden") {
          void flushAllPendingPatches();
          return;
        }
        void (async () => {
          await flushAllPendingPatches();
          if (pendingPatches.size === 0) loadRows();
        })();
      });
      window.addEventListener("pagehide", () => {
        void flushAllPendingPatches();
      });
      window.addEventListener("beforeunload", () => {
        void flushAllPendingPatches();
      });

      const fechaSortTh = document.getElementById("th-sort-fecha");
      if (fechaSortTh) {
        fechaSortTh.addEventListener("click", handleFechaSortHeaderToggle);
        fechaSortTh.addEventListener("keydown", (e) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            handleFechaSortHeaderToggle();
          }
        });
      }
      syncFechaSortHeader();
      loadRows();
    </script>
  </body>
</html>
