---
import { withBase } from "@/lib/basePath";
const returnUrl = withBase("/la-torre-2026/muestras");
const SUPA_URL = import.meta.env.PUBLIC_SUPABASE_URL;
const SUPA_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/png" href={withBase("/img/logo-la-torre-stone-fruit.png")} />
    <title>Nuevo lote — La Torre Stone Fruits</title>
    <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
    <script is:inline define:vars={{ SUPA_URL, SUPA_KEY }}>
      window._supaUrl = SUPA_URL;
      window._supaKey = SUPA_KEY;
    </script>
    <script is:inline src={withBase("/js/fruitstone-camara-map.js")}></script>
    <style is:global>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg: #f5f5f4;
        --surface: #ffffff;
        --border: #e7e5e4;
        --border-strong: #d6d3d1;
        --ink: #1c1917;
        --muted: #78716c;
        --accent: #9f1239;
        --accent-soft: #fff1f2;
        --accent-strong: #be123c;
        --header-bg: #fafaf9;
        --ok: #16a34a;
        --warn: #d97706;
        --danger: #dc2626;
      }

      html, body {
        width: 100%;
        min-height: 100dvh;
        background: var(--bg);
        color: var(--ink);
        font-family: "Aptos", "Inter", "Segoe UI", system-ui, sans-serif;
        font-size: 13px;
      }

      body { overflow-x: hidden; }

      button, input, select, textarea {
        font: inherit;
        color: inherit;
      }

      button { cursor: pointer; }

      .app {
        display: flex;
        flex-direction: column;
        min-height: 100dvh;
        width: 100%;
      }

      /* ── Toolbar ────────────────────────────────────────────────── */
      .toolbar {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 16px;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        z-index: 10;
        flex-wrap: wrap;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        padding-right: 14px;
        border-right: 1px solid var(--border);
      }

      .brand img {
        height: 40px;
        width: auto;
        max-width: 110px;
        object-fit: contain;
        display: block;
      }

      .brand-meta {
        display: flex;
        flex-direction: column;
        line-height: 1.05;
      }

      .brand-title {
        font-family: Georgia, "Times New Roman", serif;
        font-size: 16px;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--ink);
        line-height: 1;
      }

      .brand-sub {
        font-size: 10px;
        letter-spacing: 0.18em;
        color: var(--muted);
        text-transform: uppercase;
        font-weight: 700;
        margin-top: 3px;
      }

      .toolbar-spacer { flex: 1; }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        height: 32px;
        padding: 0 12px;
        border: 1px solid var(--border-strong);
        border-radius: 6px;
        background: var(--surface);
        color: var(--ink);
        font-weight: 600;
        font-size: 12.5px;
        text-decoration: none;
        transition: background 140ms ease, border-color 140ms ease, color 140ms ease;
      }

      .btn:hover {
        background: var(--accent-soft);
        border-color: var(--accent);
        color: var(--accent);
      }

      .btn-primary {
        background: var(--accent);
        border-color: var(--accent);
        color: white;
      }

      .btn-primary:hover {
        background: var(--accent-strong);
        border-color: var(--accent-strong);
        color: white;
      }

      .btn .icon { font-size: 14px; line-height: 1; }

      /* ── Layout principal ───────────────────────────────────────── */
      .form-wrap {
        width: min(1380px, 100%);
        margin: 0 auto;
        padding: 18px 16px 24px;
        display: flex;
        flex-direction: column;
        gap: 18px;
      }

      .page-title {
        display: flex;
        align-items: baseline;
        gap: 14px;
        margin: 4px 2px 0;
      }

      .page-title h1 {
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(24px, 3vw, 32px);
        letter-spacing: -0.03em;
        color: var(--ink);
        line-height: 1;
      }

      .page-title small {
        color: var(--muted);
        font-size: 13px;
        font-weight: 600;
      }

      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
      }

      .card-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 12px 16px;
        border-bottom: 1px solid var(--border);
        background: var(--header-bg);
      }

      .card-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 800;
        font-size: 12.5px;
        color: var(--accent);
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .card-title .num {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 22px;
        height: 22px;
        padding: 0 7px;
        background: var(--accent);
        color: white;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0;
      }

      .card-body {
        padding: 14px 16px;
      }

      /* ── Inputs ─────────────────────────────────────────────────── */
      .field {
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-width: 0;
      }

      .field label {
        font-size: 10.5px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .input {
        height: 34px;
        width: 100%;
        border: 1px solid var(--border-strong);
        border-radius: 6px;
        background: var(--surface);
        padding: 0 10px;
        outline: none;
        font-size: 13px;
        font-variant-numeric: tabular-nums;
        transition: border-color 140ms ease, box-shadow 140ms ease;
      }

      .input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(190, 18, 60, 0.12);
      }

      .input[readonly] {
        background: var(--header-bg);
        color: var(--ink);
        font-weight: 700;
        cursor: default;
      }

      .input[readonly]:focus {
        border-color: var(--border-strong);
        box-shadow: none;
      }

      .input[type="number"] { text-align: right; }

      textarea.input {
        height: auto;
        min-height: 60px;
        padding: 8px 10px;
        resize: vertical;
        font-family: inherit;
        line-height: 1.4;
      }

      .lote-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: 12px;
      }

      .lote-kilos-strip {
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
      }

      /* ── Lista de muestras ──────────────────────────────────────── */
      .muestras-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      .muestra-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
      }

      .muestra-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 10px 14px;
        background: var(--header-bg);
        border-bottom: 1px solid var(--border);
      }

      .muestra-tag {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-weight: 800;
        font-size: 12px;
        color: var(--ink);
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .muestra-tag .num {
        min-width: 24px;
        height: 24px;
        padding: 0 8px;
        background: var(--accent-soft);
        color: var(--accent);
        border: 1px solid rgba(159, 18, 57, 0.2);
        border-radius: 4px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 11.5px;
      }

      .muestra-stats {
        display: flex;
        align-items: center;
        gap: 14px;
        font-size: 12px;
        color: var(--muted);
      }

      .muestra-stats strong {
        color: var(--ink);
        font-variant-numeric: tabular-nums;
        font-weight: 700;
      }

      .muestra-stats .status {
        margin-left: 4px;
        padding: 3px 8px;
        border-radius: 4px;
        font-size: 10.5px;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .status-ok { background: #dcfce7; color: var(--ok); }
      .status-warn { background: #fef3c7; color: var(--warn); }
      .status-danger { background: #fee2e2; color: var(--danger); }

      .muestra-body {
        padding: 14px;
        display: grid;
        gap: 14px;
        grid-template-columns: 1fr;
      }

      .muestra-row {
        display: grid;
        gap: 10px;
      }

      .muestra-row.top {
        grid-template-columns: minmax(0, 240px);
      }

      .muestra-row.calibres {
        grid-template-columns: repeat(7, minmax(0, 1fr));
      }

      .muestra-row.defectos {
        grid-template-columns: repeat(5, minmax(0, 1fr));
      }

      .muestra-row.clasificacion {
        grid-template-columns: repeat(3, minmax(0, 220px));
      }

      .section-label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 10.5px;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: -4px;
      }

      .section-label::before {
        content: "";
        width: 4px;
        height: 12px;
        background: var(--accent);
        border-radius: 2px;
      }

      /* ── Footer sticky con acciones ─────────────────────────────── */
      .footer-actions {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 16px;
        background: var(--surface);
        border-top: 1px solid var(--border);
        position: sticky;
        bottom: 0;
        z-index: 10;
        flex-wrap: wrap;
      }

      .summary {
        display: flex;
        align-items: center;
        gap: 16px;
        color: var(--muted);
        font-size: 12.5px;
      }

      .summary strong {
        color: var(--ink);
        font-variant-numeric: tabular-nums;
        font-weight: 800;
      }

      .summary .sep { width: 1px; height: 14px; background: var(--border); }

      .footer-buttons {
        display: flex;
        gap: 8px;
      }

      .feedback {
        font-size: 12px;
        color: var(--danger);
        font-weight: 700;
      }

      .feedback.ok { color: var(--ok); }

      /* ── Upload de imágenes ─────────────────────────────────────── */
      .image-drop {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 4px;
        min-height: 110px;
        border: 1.5px dashed var(--border-strong);
        border-radius: 10px;
        background: var(--header-bg);
        color: var(--muted);
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        text-align: center;
        padding: 14px;
        transition: border-color 140ms ease, background 140ms ease, color 140ms ease;
      }

      .image-drop:hover {
        border-color: var(--accent);
        background: var(--accent-soft);
        color: var(--accent);
      }

      .image-drop .icon-big {
        font-size: 20px;
        line-height: 1;
        margin-bottom: 2px;
      }

      .image-drop .hint {
        font-size: 10.5px;
        font-weight: 600;
        color: var(--muted);
        letter-spacing: 0.04em;
      }

      .image-drop input[type="file"] {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
      }

      .pallet-area {
        display: grid;
        grid-template-columns: 1fr;
        gap: 10px;
      }

      .pallet-area.has-image {
        grid-template-columns: 160px 1fr;
      }

      .image-preview {
        position: relative;
        width: 100%;
        min-height: 110px;
        border: 1px solid var(--border-strong);
        border-radius: 10px;
        overflow: hidden;
        background: white;
        display: none;
      }

      .pallet-area.has-image .image-preview {
        display: block;
      }

      .image-preview img {
        width: 100%;
        height: 100%;
        max-height: 160px;
        object-fit: cover;
        display: block;
      }

      .image-preview .remove {
        position: absolute;
        top: 6px;
        right: 6px;
        width: 24px;
        height: 24px;
        border: 0;
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.65);
        color: white;
        font-size: 14px;
        line-height: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 140ms ease;
      }

      .image-preview .remove:hover {
        background: var(--danger);
      }

      .image-gallery {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: stretch;
      }

      .image-gallery .image-drop {
        width: 110px;
        min-height: 110px;
        flex-shrink: 0;
        padding: 8px;
        font-size: 11px;
      }

      .gallery-thumb {
        position: relative;
        width: 110px;
        height: 110px;
        border: 1px solid var(--border-strong);
        border-radius: 10px;
        overflow: hidden;
        background: white;
      }

      .gallery-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .gallery-thumb .remove {
        position: absolute;
        top: 4px;
        right: 4px;
        width: 22px;
        height: 22px;
        border: 0;
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.65);
        color: white;
        font-size: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .gallery-thumb .remove:hover {
        background: var(--danger);
      }

      /* ── Responsive ─────────────────────────────────────────────── */
      @media (max-width: 980px) {
        .lote-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .lote-kilos-strip { grid-template-columns: 1fr; }
        .muestra-row.calibres { grid-template-columns: repeat(3, minmax(0, 1fr)); }
        .muestra-row.defectos { grid-template-columns: repeat(4, minmax(0, 1fr)); }
        .muestra-row.top { grid-template-columns: minmax(0, 220px); }
      }

      @media (max-width: 600px) {
        .lote-grid { grid-template-columns: 1fr 1fr; }
        .lote-kilos-strip { grid-template-columns: 1fr; }
        .muestra-row.calibres { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .muestra-row.defectos { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .muestra-row.clasificacion { grid-template-columns: 1fr; }
        .muestra-row.top { grid-template-columns: 1fr; }
        .muestra-stats { gap: 8px; font-size: 11.5px; }
        .brand { gap: 8px; padding-right: 10px; }
        .brand img { height: 32px; max-width: 90px; }
        .brand-title { font-size: 14px; }
        .brand-sub { font-size: 9.5px; letter-spacing: 0.14em; }
      }

      /* ── Mapa cámara (nuevo lote) — mismo lenguaje visual que tabla principal ─ */
      .camara-map-block {
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid var(--border);
      }

      .camara-map-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 8px;
      }

      .camara-map-block.is-collapsed .camara-map-toolbar {
        margin-bottom: 4px;
      }

      .camara-map-block.is-collapsed .camara-map-expandable {
        display: none;
      }

      .camara-map-collapsed-note {
        display: none;
        margin: 0 0 8px;
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
        line-height: 1.35;
      }

      .camara-map-block.is-collapsed .camara-map-collapsed-note {
        display: block;
      }

      .camara-map-toggle {
        flex-shrink: 0;
        padding: 6px 12px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.04em;
      }

      .camara-map-block .block-title {
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 0;
      }

      .camara-map-hint {
        font-size: 12px;
        color: var(--muted);
        margin-bottom: 12px;
        line-height: 1.45;
      }

      #camara-map-nuevo-root {
        overflow-x: auto;
        padding-bottom: 4px;
      }

      .camara-draft-row {
        margin-top: 10px;
        font-size: 12px;
        font-weight: 700;
        color: var(--ink);
      }

      .camara-actions {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 12px;
        margin-top: 10px;
      }

      #camara-clear-selection-btn {
        margin-right: auto;
      }

      .camara-confirmed {
        font-size: 12px;
        font-weight: 700;
        color: var(--ok);
      }

      .lt-fridge-root {
        max-width: 1400px;
      }

      .lt-fridge-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 10px 16px;
        margin-bottom: 10px;
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
      }

      .lt-leg {
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }

      .lt-leg::before {
        content: "";
        width: 12px;
        height: 12px;
        border-radius: 2px;
        border: 1px solid var(--border-strong);
      }

      .lt-leg-free::before {
        background: #f5f5f4;
      }

      .lt-leg-occ::before {
        background: #e0e7ff;
        border-color: #6366f1;
      }

      .lt-leg-dbl::before {
        background: linear-gradient(180deg, #c7d2fe 50%, #a5b4fc 50%);
        border-color: #4338ca;
      }

      .lt-leg-depth::before {
        background: #e0f2fe;
        border-color: #0284c7;
      }

      .lt-leg-b1::before {
        background: #fce7f3;
        border-color: #db2777;
      }

      .lt-leg-multi::before {
        background: #dbeafe;
        border-color: #1d4ed8;
      }

      .lt-fridge-slot--ghost {
        background: linear-gradient(180deg, #eff6ff 0%, #dbeafe 100%);
        border-color: #3b82f6;
      }

      .lt-fridge-slot--draft-toggle {
        outline: 2px dashed #1d4ed8;
        outline-offset: 1px;
      }

      .lt-fridge-colhead--b1 {
        color: #9d174d;
      }

      .lt-fridge-slot--na {
        background: #f4f4f5;
        opacity: 0.75;
      }

      .lt-fridge-grid {
        display: grid;
        gap: 3px;
        align-items: stretch;
      }

      .lt-fridge-corner,
      .lt-fridge-colhead,
      .lt-fridge-rowhead {
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
        padding: 4px 2px;
        text-align: center;
        line-height: 1.15;
      }

      .lt-fridge-rowhead {
        justify-content: flex-end;
        padding-right: 6px;
      }

      .lt-fridge-cell {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-height: 72px;
      }

      .lt-fridge-cell--double {
        outline: 2px solid #4338ca;
        outline-offset: 1px;
        border-radius: 2px;
      }

      .lt-fridge-slot {
        flex: 1;
        min-height: 32px;
        border: 1px solid var(--border-strong);
        border-radius: 2px;
        background: #fafaf9;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1px;
        padding: 3px 4px;
        text-align: center;
        transition: background 140ms ease, border-color 140ms ease;
      }

      button.lt-fridge-slot {
        font: inherit;
        cursor: pointer;
      }

      .lt-fridge-slot--empty {
        background: #f5f5f4;
      }

      .lt-fridge-slot--blocked {
        background: #e7e5e4;
        color: var(--muted);
        cursor: not-allowed;
        opacity: 0.75;
      }

      .lt-fridge-slot--occupied {
        background: linear-gradient(180deg, #eef2ff 0%, #e0e7ff 100%);
        border-color: #818cf8;
        color: var(--ink);
      }

      .lt-fridge-slot--picked {
        outline: 2px solid var(--accent);
        outline-offset: 1px;
        border-color: var(--accent);
        box-shadow: 0 0 0 2px rgba(159, 18, 57, 0.12);
      }

      .lt-slot-coord {
        font-size: 9px;
        font-weight: 800;
        letter-spacing: 0.04em;
        color: #4338ca;
      }

      .lt-slot-fruit {
        font-size: 10px;
        font-weight: 700;
        line-height: 1.1;
        max-width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .lt-slot-lote {
        font-size: 9px;
        font-weight: 700;
        color: var(--muted);
        font-variant-numeric: tabular-nums;
      }

      .lt-slot-prod {
        font-size: 8px;
        color: var(--muted);
        max-width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .lt-slot-free-label {
        font-size: 9px;
        font-weight: 700;
        color: #a8a29e;
      }

      .lt-slot-blocked-label {
        font-size: 9px;
        font-weight: 800;
        color: #78716c;
      }

      .lt-fridge-foot {
        margin-top: 10px;
        text-align: center;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
      }
    </style>
  </head>
  <body data-return-url={returnUrl}>
    <div class="app">
      <header class="toolbar">
        <div class="brand">
          <img src={withBase("/img/logo-la-torre-stone-fruit.png")} alt="La Torre Stone Fruits" />
          <div class="brand-meta">
            <div class="brand-title">La Torre Stone Fruits</div>
            <div class="brand-sub">Nuevo lote</div>
          </div>
        </div>
        <a class="btn" href={returnUrl}>
          <span class="icon">←</span> Volver
        </a>
        <div class="toolbar-spacer"></div>
        <span class="feedback" id="feedback"></span>
        <button class="btn btn-primary" type="button" id="save-btn">
          <span class="icon">✓</span> Guardar lote
        </button>
      </header>

      <main class="form-wrap">
        <div class="page-title">
          <h1>Nuevo lote</h1>
          <small id="muestras-counter"></small>
        </div>

        <section class="card" aria-labelledby="lote-title">
          <div class="card-head">
            <div class="card-title">
              <span class="num">1</span>
              <span id="lote-title">Datos del lote</span>
            </div>
          </div>
          <div class="card-body">
            <div class="lote-grid">
              <div class="field">
                <label for="lote-fecha">Fecha</label>
                <input class="input" id="lote-fecha" type="date" />
              </div>
              <div class="field">
                <label for="lote-lote">Lote</label>
                <input class="input" id="lote-lote" type="text" placeholder="L001" autocomplete="off" />
              </div>
              <div class="field">
                <label for="lote-productor">Productor</label>
                <input class="input" id="lote-productor" type="text" placeholder="Huerto Norte" autocomplete="off" />
              </div>
              <div class="field">
                <label for="lote-variedad">Variedad</label>
                <input class="input" id="lote-variedad" list="variedades" type="text" placeholder="Santina" autocomplete="off" />
                <datalist id="variedades">
                  <option value="Santina"></option>
                  <option value="Lapins"></option>
                  <option value="Bing"></option>
                  <option value="Kordia"></option>
                  <option value="Sweetheart"></option>
                  <option value="Regina"></option>
                  <option value="Skeena"></option>
                  <option value="Royal Dawn"></option>
                </datalist>
              </div>
              <div class="lote-kilos-strip">
                <div class="field">
                  <label for="lote-cajas">Cantidad de cajas</label>
                  <input class="input" id="lote-cajas" type="text" inputmode="decimal" placeholder="25+50" autocomplete="off" title="Varios pallets: suma con + (ej. 25+50). Enter o salir para calcular." />
                </div>
                <div class="field">
                  <label for="lote-kilos-bruto">Kilos bruto lote</label>
                  <input class="input" id="lote-kilos-bruto" type="text" inputmode="decimal" placeholder="1200+800" autocomplete="off" title="Varios pallets: suma con +. Enter o salir para calcular." />
                </div>
                <div class="field">
                  <label for="lote-kilos-neto">Kilos neto lote</label>
                  <input class="input" id="lote-kilos-neto" type="text" inputmode="decimal" placeholder="1100+750" autocomplete="off" title="Varios pallets: suma con +. Enter o salir para calcular." />
                </div>
              </div>
            </div>

            <div class="camara-map-block" id="camara-map-block">
              <div class="camara-map-toolbar">
                <div class="block-title">Ubicación en cámara frigorífica</div>
                <button
                  type="button"
                  class="btn camara-map-toggle"
                  id="btn-toggle-camara-map"
                  aria-expanded="true"
                  aria-controls="camara-map-expandable"
                >
                  Minimizar mapa
                </button>
              </div>
              <p class="camara-map-collapsed-note" id="camara-map-collapsed-note">
                Plano oculto para ganar espacio. Las coordenadas confirmadas siguen abajo. Pulse «Mostrar mapa» para seguir eligiendo celdas.
              </p>
              <div id="camara-map-expandable" class="camara-map-expandable">
                <p class="camara-map-hint">
                  <strong>12 bandas horizontales</strong> (B1…B12). <strong>Profundidad</strong> en filas P1 (fondo) → P2, P3… hacia la cara de acceso; la <strong>puerta está al final de la banda B1</strong> (frente a la última posición permitida en B1).
                  En <strong>B1 solo hay 3 posiciones</strong> en profundidad (P1–P3); el resto de bandas admite más filas P. Puede colocar el lote en <strong>cualquier celda libre</strong> del plano. Puede <strong>elegir varias celdas</strong> si el mismo lote está repartido en más de un lugar; pulse de nuevo una celda elegida para quitarla. Luego «Confirmar ubicación».
                </p>
                <div id="camara-map-nuevo-root" aria-live="polite"></div>
                <div class="camara-draft-row" id="camara-draft-label">Selección pendiente: —</div>
                <div class="camara-actions">
                  <button type="button" class="btn" id="camara-clear-selection-btn">
                    Vaciar selección
                  </button>
                  <button type="button" class="btn btn-primary" id="camara-confirm-btn" disabled>
                    Confirmar ubicación
                  </button>
                  <span class="camara-confirmed" id="camara-confirmed-label"></span>
                </div>
              </div>
              <div class="field" style="margin-top: 12px;">
                <label for="lote-bandas">Coordenadas B-P (se rellenan al confirmar; varias con +)</label>
                <input class="input" id="lote-bandas" type="text" readonly placeholder="Ej: B5-P2 o B2-P1+B8-P2" autocomplete="off" />
              </div>
            </div>

            <div class="field" style="margin-top: 14px;">
              <label>Etiqueta del pallet (foto)</label>
              <div class="pallet-area" id="pallet-area">
                <div class="image-preview" id="pallet-preview">
                  <img id="pallet-img" alt="Etiqueta del pallet" />
                  <button type="button" class="remove" id="pallet-remove" aria-label="Quitar etiqueta">×</button>
                </div>
                <label class="image-drop" for="pallet-input">
                  <span class="icon-big">+</span>
                  <span>Subir foto de la etiqueta</span>
                  <span class="hint">Toca para tomar foto o elegir archivo</span>
                  <input type="file" id="pallet-input" accept="image/*" capture="environment" />
                </label>
              </div>
            </div>
          </div>
        </section>

        <section class="card" aria-labelledby="muestras-title">
          <div class="card-head">
            <div class="card-title">
              <span class="num">2</span>
              <span id="muestras-title">Muestra</span>
            </div>
          </div>
          <div class="card-body">
            <div class="muestras-list" id="muestras-list"></div>
          </div>
        </section>
      </main>

      <footer class="footer-actions">
        <div class="summary">
          <span><strong id="sum-frutos">0</strong> frutos</span>
          <span class="sep"></span>
          <span><strong id="sum-defectos">0%</strong> defectos</span>
          <span class="sep"></span>
          <span><strong id="sum-exportable">0%</strong> exportable</span>
        </div>
        <div class="footer-buttons">
          <a class="btn" href={returnUrl}>Cancelar</a>
          <button class="btn btn-primary" type="button" id="save-btn-footer">
            <span class="icon">✓</span> Guardar lote
          </button>
        </div>
      </footer>
    </div>

    <script is:inline>
      const returnUrl = document.body.dataset.returnUrl;
      const BUCKET = "fruitstone2026";
      const TABLE = "fruitstone2026_muestras";

      const supa = window.supabase && window._supaUrl && window._supaKey
        ? window.supabase.createClient(window._supaUrl, window._supaKey)
        : null;

      const calibres = [
        { id: "cPre", label: "P/C" },
        { id: "c22", label: "22-24" },
        { id: "c24", label: "24-26" },
        { id: "c26", label: "26-28" },
        { id: "c28", label: "28-30" },
        { id: "c30", label: "30-32" },
        { id: "c32", label: "+34" }
      ];

      const defectos = [
        { id: "blanda", label: "Blanda" },
        { id: "pitting", label: "Pitting" },
        { id: "doble", label: "Doble" },
        { id: "deshidratada", label: "Deshidratada" },
        { id: "partida", label: "Partida" },
        { id: "pudricion", label: "Pudrición" },
        { id: "colorBajo", label: "Falta color" },
        { id: "mediaLuna", label: "Media luna" },
        { id: "sinPedicelo", label: "Sin pedicelo" },
        { id: "negro", label: "Negro" }
      ];

      const ZUMO_KEYS = ["pudricion", "colorBajo", "negro"];
      const SEGUNDA_KEYS = ["blanda", "pitting", "doble", "partida"];

      function sumZumo(m) {
        return ZUMO_KEYS.reduce((acc, k) => acc + asNumber(m[k]), 0);
      }

      function sumSegunda(m) {
        return SEGUNDA_KEYS.reduce((acc, k) => acc + asNumber(m[k]), 0);
      }

      function sumPrimera(m) {
        return Math.max(0, asNumber(m.total) - sumZumo(m) - sumSegunda(m));
      }

      function blankMuestra() {
        const base = { total: 0, primera: 0, segunda: 0, zumo: 0, observaciones: "", fotosDefectos: [] };
        for (const c of calibres) base[c.id] = 0;
        for (const d of defectos) base[d.id] = 0;
        return base;
      }

      function sumCalibres(m) {
        return calibres.reduce((acc, c) => acc + asNumber(m[c.id]), 0);
      }

      const MAX_DIM = 1600;
      const QUALITY = 0.82;

      function compressImage(file) {
        return new Promise((resolve, reject) => {
          if (!file || !file.type.startsWith("image/")) {
            reject(new Error("Archivo no es una imagen"));
            return;
          }
          const reader = new FileReader();
          reader.onerror = () => reject(reader.error);
          reader.onload = () => {
            const img = new Image();
            img.onerror = () => reject(new Error("No se pudo leer la imagen"));
            img.onload = () => {
              let { width, height } = img;
              if (width > MAX_DIM || height > MAX_DIM) {
                if (width >= height) {
                  height = Math.round((MAX_DIM / width) * height);
                  width = MAX_DIM;
                } else {
                  width = Math.round((MAX_DIM / height) * width);
                  height = MAX_DIM;
                }
              }
              const canvas = document.createElement("canvas");
              canvas.width = width;
              canvas.height = height;
              const ctx = canvas.getContext("2d");
              if (!ctx) {
                reject(new Error("No se pudo crear canvas"));
                return;
              }
              ctx.drawImage(img, 0, 0, width, height);
              canvas.toBlob((blob) => {
                if (blob) resolve(blob);
                else reject(new Error("No se pudo comprimir la imagen"));
              }, "image/jpeg", QUALITY);
            };
            img.src = String(reader.result);
          };
          reader.readAsDataURL(file);
        });
      }

      function sanitizePath(str) {
        return String(str || "sin-lote")
          .toLowerCase()
          .normalize("NFD")
          .replace(/[\u0300-\u036f]/g, "")
          .replace(/[^a-z0-9-]+/g, "-")
          .replace(/^-+|-+$/g, "")
          .slice(0, 40) || "sin-lote";
      }

      async function uploadImage(blob, folder, prefix) {
        if (!supa) throw new Error("Supabase no está disponible.");
        const rand = Math.random().toString(36).slice(2, 8);
        const path = `${folder}/${sanitizePath(prefix)}-${Date.now()}-${rand}.jpg`;
        const { error } = await supa.storage.from(BUCKET).upload(path, blob, {
          contentType: "image/jpeg",
          upsert: false
        });
        if (error) throw error;
        const { data } = supa.storage.from(BUCKET).getPublicUrl(path);
        return data.publicUrl;
      }

      function asNumber(value) {
        const n = Number(value);
        return Number.isFinite(n) ? n : 0;
      }

      function pct(value, total) {
        if (!total) return 0;
        return (value / total) * 100;
      }

      function formatPct(value) {
        return `${value.toLocaleString("es-CL", { maximumFractionDigits: 1 })}%`;
      }

      function calcular(m) {
        const total = asNumber(m.total);
        const sumDef = defectos.reduce((acc, d) => acc + asNumber(m[d.id]), 0);
        const zumo = sumZumo(m);
        const exportable = Math.max(0, total - zumo);
        const sumCal = calibres.reduce((acc, c) => acc + asNumber(m[c.id]), 0);
        const defectPct = pct(sumDef, total);
        const exportablePct = pct(exportable, total);
        const estado = asNumber(m.pudricion) > 0 || defectPct > 10
          ? "critico"
          : defectPct > 5
            ? "alerta"
            : "ok";
        return { total, sumDef, exportable, sumCal, defectPct, exportablePct, estado };
      }

      const muestra = blankMuestra();
      const lote = {
        fecha: new Date().toISOString().slice(0, 10),
        lote: "",
        productor: "",
        variedad: "",
        bandasCamara: "",
        camaraBanda: null,
        camaraPosicion: null,
        camaraAltura: null,
        cantidadCajas: null,
        kilosBrutoLote: null,
        kilosNetoLote: null,
        etiquetaPallet: ""
      };

      /** @type {{ b: number; p: number; h: number }[]} */
      let camaraDraftSlots = [];
      let occupancyRows = [];

      async function fetchCamaraOccupancy() {
        if (!supa) return;
        const { data, error } = await supa
          .from(TABLE)
          .select("id,procesado,camara_banda,camara_posicion,camara_altura,bandas_camara,lote,variedad,productor")
          .eq("procesado", false);
        if (error) return;
        occupancyRows = (data ?? []).map((r) => ({
          id: r.id,
          procesado: false,
          lote: r.lote,
          variedad: r.variedad,
          productor: r.productor,
          camara_banda: r.camara_banda,
          camara_posicion: r.camara_posicion,
          camara_altura: r.camara_altura,
          bandas_camara: r.bandas_camara
        }));
        refreshCamaraMapNuevo();
      }

      function clearCamaraNuevoSelection() {
        camaraDraftSlots = [];
        lote.bandasCamara = "";
        lote.camaraBanda = null;
        lote.camaraPosicion = null;
        lote.camaraAltura = null;
        const bandInput = document.getElementById("lote-bandas");
        if (bandInput) bandInput.value = "";
        const conf = document.getElementById("camara-confirmed-label");
        if (conf) conf.textContent = "";
        const draftLabel = document.getElementById("camara-draft-label");
        if (draftLabel) {
          draftLabel.textContent =
            "Selección pendiente: — (pulse celdas libres; varias si el lote está en más de un sitio)";
        }
        const confirmBtn = document.getElementById("camara-confirm-btn");
        if (confirmBtn) confirmBtn.disabled = true;
        const fb = document.getElementById("feedback");
        if (fb) {
          fb.classList.remove("ok");
          fb.textContent = "";
        }
        refreshCamaraMapNuevo();
      }

      function refreshCamaraMapNuevo() {
        const root = document.getElementById("camara-map-nuevo-root");
        if (!root || !window.LaTorreCamaraMap) return;
        const draftLabel = document.getElementById("camara-draft-label");
        const confirmBtn = document.getElementById("camara-confirm-btn");
        const M = window.LaTorreCamaraMap;
        M.render(root, occupancyRows, {
          mode: "pick",
          excludeId: null,
          multiSelect: true,
          selection: camaraDraftSlots,
          editingDraftSlots: camaraDraftSlots,
          onSlotClick: (c) => {
            if (c.toggle) {
              camaraDraftSlots = camaraDraftSlots.filter(
                (s) => !M.slotsEqual(s, { b: c.b, p: c.p, h: c.h })
              );
            } else {
              const next = camaraDraftSlots.concat([{ b: c.b, p: c.p, h: c.h }]);
              if (!M.validateDraftSlots(occupancyRows, null, next)) {
                if (feedbackEl) {
                  feedbackEl.classList.remove("ok");
                  feedbackEl.textContent =
                    "No se puede añadir esa celda (ocupada, fuera del plano o celda duplicada en la selección).";
                }
                return;
              }
              camaraDraftSlots = next;
            }
            if (draftLabel) {
              draftLabel.textContent = camaraDraftSlots.length
                ? "Selección pendiente: " + M.encodeSlotsText(camaraDraftSlots)
                : "Selección pendiente: — (pulse celdas libres; pulse de nuevo una elegida para quitarla)";
            }
            if (confirmBtn) confirmBtn.disabled = camaraDraftSlots.length === 0;
            refreshCamaraMapNuevo();
          }
        });
        if (draftLabel && camaraDraftSlots.length === 0) {
          draftLabel.textContent =
            "Selección pendiente: — (pulse celdas libres; varias si el lote está en más de un sitio)";
        }
        if (confirmBtn) confirmBtn.disabled = camaraDraftSlots.length === 0;
      }

      async function prefillFromLastSample() {
        if (!supa) return;
        try {
          const { data } = await supa
            .from(TABLE)
            .select("productor,variedad")
            .order("created_at", { ascending: false })
            .limit(1);
          if (data && data.length) {
            const last = data[0];
            if (!lote.productor) loteProductor.value = lote.productor = last.productor ?? "";
            if (!lote.variedad) loteVariedad.value = lote.variedad = last.variedad ?? "";
          }
        } catch {}
      }

      const loteFecha = document.getElementById("lote-fecha");
      const loteLote = document.getElementById("lote-lote");
      const loteProductor = document.getElementById("lote-productor");
      const loteVariedad = document.getElementById("lote-variedad");
      const loteCajas = document.getElementById("lote-cajas");
      const loteKilosBruto = document.getElementById("lote-kilos-bruto");
      const loteKilosNeto = document.getElementById("lote-kilos-neto");
      const loteBandas = document.getElementById("lote-bandas");

      loteFecha.value = lote.fecha;

      function sumFromPlusExpression(raw) {
        const s = String(raw ?? "").trim();
        if (!s) return null;
        const parts = s.split("+").map((p) => p.trim().replace(",", ".")).filter(Boolean);
        if (!parts.length) return null;
        let sum = 0;
        let any = false;
        for (const p of parts) {
          const n = Number(p);
          if (Number.isFinite(n)) {
            sum += n;
            any = true;
          }
        }
        return any ? sum : null;
      }

      function commitCajasKilos() {
        const cTrim = loteCajas.value.trim();
        if (!cTrim) {
          lote.cantidadCajas = null;
          loteCajas.value = "";
        } else {
          const sum = sumFromPlusExpression(cTrim);
          if (sum != null) {
            lote.cantidadCajas = Math.round(sum);
            loteCajas.value = String(lote.cantidadCajas);
          }
        }
        const kTrim = loteKilosBruto.value.trim();
        if (!kTrim) {
          lote.kilosBrutoLote = null;
          loteKilosBruto.value = "";
        } else {
          const sum = sumFromPlusExpression(kTrim);
          if (sum != null) {
            lote.kilosBrutoLote = Math.round(sum * 100) / 100;
            loteKilosBruto.value = lote.kilosBrutoLote.toLocaleString("es-CL", {
              minimumFractionDigits: 0,
              maximumFractionDigits: 2
            });
          }
        }
        const nTrim = loteKilosNeto.value.trim();
        if (!nTrim) {
          lote.kilosNetoLote = null;
          loteKilosNeto.value = "";
        } else {
          const sumN = sumFromPlusExpression(nTrim);
          if (sumN != null) {
            lote.kilosNetoLote = Math.round(sumN * 100) / 100;
            loteKilosNeto.value = lote.kilosNetoLote.toLocaleString("es-CL", {
              minimumFractionDigits: 0,
              maximumFractionDigits: 2
            });
          }
        }
      }

      loteFecha.addEventListener("input", () => { lote.fecha = loteFecha.value; });
      loteLote.addEventListener("input", () => { lote.lote = loteLote.value; });
      loteProductor.addEventListener("input", () => { lote.productor = loteProductor.value; });
      loteVariedad.addEventListener("input", () => { lote.variedad = loteVariedad.value; });
      loteCajas.addEventListener("blur", commitCajasKilos);
      loteKilosBruto.addEventListener("blur", commitCajasKilos);
      loteKilosNeto.addEventListener("blur", commitCajasKilos);
      loteCajas.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
          e.preventDefault();
          commitCajasKilos();
          loteCajas.blur();
        }
      });
      loteKilosBruto.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
          e.preventDefault();
          commitCajasKilos();
          loteKilosBruto.blur();
        }
      });
      loteKilosNeto.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
          e.preventDefault();
          commitCajasKilos();
          loteKilosNeto.blur();
        }
      });

      const palletArea = document.getElementById("pallet-area");
      const palletInput = document.getElementById("pallet-input");
      const palletImg = document.getElementById("pallet-img");
      const palletRemove = document.getElementById("pallet-remove");

      function renderPalletPreview() {
        if (lote.etiquetaPallet) {
          palletImg.src = lote.etiquetaPallet;
          palletArea.classList.add("has-image");
        } else {
          palletImg.removeAttribute("src");
          palletArea.classList.remove("has-image");
        }
      }

      let palletUploading = false;

      palletInput.addEventListener("change", async () => {
        const file = palletInput.files?.[0];
        if (!file) return;
        if (!supa) {
          feedbackEl.classList.remove("ok");
          feedbackEl.textContent = "No hay conexión con Supabase.";
          palletInput.value = "";
          return;
        }
        palletUploading = true;
        feedbackEl.classList.remove("ok");
        feedbackEl.textContent = "Subiendo etiqueta...";
        try {
          const blob = await compressImage(file);
          const url = await uploadImage(blob, "etiquetas", lote.lote);
          lote.etiquetaPallet = url;
          renderPalletPreview();
          feedbackEl.textContent = "";
        } catch (e) {
          feedbackEl.classList.remove("ok");
          feedbackEl.textContent = "No se pudo subir la imagen: " + (e?.message ?? "");
        } finally {
          palletUploading = false;
          palletInput.value = "";
        }
      });

      palletRemove.addEventListener("click", () => {
        lote.etiquetaPallet = "";
        renderPalletPreview();
      });

      const muestrasList = document.getElementById("muestras-list");
      const counterEl = document.getElementById("muestras-counter");
      const feedbackEl = document.getElementById("feedback");
      const sumFrutosEl = document.getElementById("sum-frutos");
      const sumDefectosEl = document.getElementById("sum-defectos");
      const sumExportableEl = document.getElementById("sum-exportable");

      const camaraConfirmBtn = document.getElementById("camara-confirm-btn");
      if (camaraConfirmBtn) {
        camaraConfirmBtn.addEventListener("click", () => {
          if (!camaraDraftSlots.length || !window.LaTorreCamaraMap) return;
          const M = window.LaTorreCamaraMap;
          const slots = camaraDraftSlots.map((s) => ({ b: s.b, p: s.p, h: s.h }));
          if (!M.validateDraftSlots(occupancyRows, null, slots)) {
            if (feedbackEl) {
              feedbackEl.classList.remove("ok");
              feedbackEl.textContent = "La selección ya no es válida (ocupación o plano). Actualizamos el mapa.";
            }
            fetchCamaraOccupancy();
            return;
          }
          const enc = M.encodeSlotsText(slots);
          if (slots.length === 1) {
            const c = slots[0];
            lote.camaraBanda = c.b;
            lote.camaraPosicion = c.p;
            lote.camaraAltura = c.h;
          } else {
            lote.camaraBanda = null;
            lote.camaraPosicion = null;
            lote.camaraAltura = 1;
          }
          lote.bandasCamara = enc;
          const bandInput = document.getElementById("lote-bandas");
          if (bandInput) bandInput.value = lote.bandasCamara;
          const conf = document.getElementById("camara-confirmed-label");
          if (conf) conf.textContent = "Ubicación confirmada: " + lote.bandasCamara;
          camaraDraftSlots = [];
          camaraConfirmBtn.disabled = true;
          refreshCamaraMapNuevo();
          if (feedbackEl) {
            feedbackEl.classList.remove("ok");
            feedbackEl.textContent = "";
          }
        });
      }

      const camaraClearBtn = document.getElementById("camara-clear-selection-btn");
      if (camaraClearBtn) {
        camaraClearBtn.addEventListener("click", clearCamaraNuevoSelection);
      }

      fetchCamaraOccupancy();
      setInterval(() => {
        if (document.visibilityState === "visible") fetchCamaraOccupancy();
      }, 25000);

      const camaraMapBlock = document.getElementById("camara-map-block");
      const toggleCamaraMapBtn = document.getElementById("btn-toggle-camara-map");
      if (toggleCamaraMapBtn && camaraMapBlock) {
        toggleCamaraMapBtn.addEventListener("click", () => {
          const collapsed = camaraMapBlock.classList.toggle("is-collapsed");
          toggleCamaraMapBtn.setAttribute("aria-expanded", collapsed ? "false" : "true");
          toggleCamaraMapBtn.textContent = collapsed ? "Mostrar mapa" : "Minimizar mapa";
          if (!collapsed) refreshCamaraMapNuevo();
        });
      }

      function createNumberField(label, value, onChange) {
        const wrap = document.createElement("div");
        wrap.className = "field";
        const lbl = document.createElement("label");
        lbl.textContent = label;
        const input = document.createElement("input");
        input.type = "number";
        input.className = "input";
        input.min = "0";
        input.step = "1";
        input.value = String(value);
        input.addEventListener("input", () => onChange(asNumber(input.value)));
        wrap.appendChild(lbl);
        wrap.appendChild(input);
        return wrap;
      }

      function renderMuestra(muestra) {
        const card = document.createElement("article");
        card.className = "muestra-card";

        const head = document.createElement("div");
        head.className = "muestra-head";

        const tag = document.createElement("span");
        tag.className = "muestra-tag";
        const labelTxt = document.createElement("span");
        labelTxt.textContent = "Muestra";
        tag.appendChild(labelTxt);

        const stats = document.createElement("div");
        stats.className = "muestra-stats";
        stats.dataset.role = "stats";

        head.appendChild(tag);
        head.appendChild(stats);

        const body = document.createElement("div");
        body.className = "muestra-body";

        muestra.total = sumCalibres(muestra);

        let primeraInput, segundaInput, zumoInput;

        const refreshClasificacion = () => {
          muestra.zumo = sumZumo(muestra);
          muestra.segunda = sumSegunda(muestra);
          muestra.primera = sumPrimera(muestra);
          if (primeraInput) primeraInput.value = String(muestra.primera);
          if (segundaInput) segundaInput.value = String(muestra.segunda);
          if (zumoInput) zumoInput.value = String(muestra.zumo);
        };

        const top = document.createElement("div");
        top.className = "muestra-row top";
        const totalWrap = document.createElement("div");
        totalWrap.className = "field";
        const totalLbl = document.createElement("label");
        totalLbl.textContent = "Total frutos (suma calibres)";
        const totalInput = document.createElement("input");
        totalInput.type = "number";
        totalInput.className = "input";
        totalInput.readOnly = true;
        totalInput.tabIndex = -1;
        totalInput.value = String(muestra.total);
        totalWrap.appendChild(totalLbl);
        totalWrap.appendChild(totalInput);
        top.appendChild(totalWrap);
        body.appendChild(top);

        const labelCal = document.createElement("div");
        labelCal.className = "section-label";
        labelCal.textContent = "Calibres (P/C = precalibre < 22 mm) — el total se calcula sumándolos";
        body.appendChild(labelCal);

        const calRow = document.createElement("div");
        calRow.className = "muestra-row calibres";
        for (const c of calibres) {
          calRow.appendChild(createNumberField(c.label, muestra[c.id], (v) => {
            muestra[c.id] = v;
            muestra.total = sumCalibres(muestra);
            totalInput.value = String(muestra.total);
            refreshClasificacion();
            updateStats(stats, muestra);
            updateSummary();
          }));
        }
        body.appendChild(calRow);

        const labelDef = document.createElement("div");
        labelDef.className = "section-label";
        labelDef.textContent = "Defectos";
        body.appendChild(labelDef);

        const defRow = document.createElement("div");
        defRow.className = "muestra-row defectos";
        for (const d of defectos) {
          defRow.appendChild(createNumberField(d.label, muestra[d.id], (v) => {
            muestra[d.id] = v;
            refreshClasificacion();
            updateStats(stats, muestra);
            updateSummary();
          }));
        }
        body.appendChild(defRow);

        const labelClas = document.createElement("div");
        labelClas.className = "section-label";
        labelClas.textContent = "Clasificación (Exportable = Primera + Segunda)";
        body.appendChild(labelClas);

        refreshClasificacion();

        const clasRow = document.createElement("div");
        clasRow.className = "muestra-row clasificacion";

        const buildClasField = (labelText) => {
          const wrap = document.createElement("div");
          wrap.className = "field";
          const lbl = document.createElement("label");
          lbl.textContent = labelText;
          const input = document.createElement("input");
          input.type = "number";
          input.className = "input";
          input.readOnly = true;
          input.tabIndex = -1;
          wrap.appendChild(lbl);
          wrap.appendChild(input);
          return { wrap, input };
        };

        const primera = buildClasField("Primera · Premium");
        primeraInput = primera.input;
        primeraInput.value = String(muestra.primera);
        clasRow.appendChild(primera.wrap);

        const segunda = buildClasField("Segunda · Comercial");
        segundaInput = segunda.input;
        segundaInput.value = String(muestra.segunda);
        clasRow.appendChild(segunda.wrap);

        const zumo = buildClasField("Zumo · Desecho");
        zumoInput = zumo.input;
        zumoInput.value = String(muestra.zumo);
        clasRow.appendChild(zumo.wrap);

        body.appendChild(clasRow);

        const obsWrap = document.createElement("div");
        obsWrap.className = "field";
        const obsLabel = document.createElement("label");
        obsLabel.textContent = "Observaciones";
        const obs = document.createElement("textarea");
        obs.className = "input";
        obs.placeholder = "Notas sobre color, firmeza, tamaño general, etc.";
        obs.value = muestra.observaciones ?? "";
        obs.addEventListener("input", () => { muestra.observaciones = obs.value; });
        obsWrap.appendChild(obsLabel);
        obsWrap.appendChild(obs);
        body.appendChild(obsWrap);

        const fotosLabel = document.createElement("div");
        fotosLabel.className = "section-label";
        fotosLabel.textContent = "Fotos de defectos";
        body.appendChild(fotosLabel);

        if (!Array.isArray(muestra.fotosDefectos)) muestra.fotosDefectos = [];
        const fotosWrap = renderFotosDefectos(muestra);
        body.appendChild(fotosWrap);

        card.appendChild(head);
        card.appendChild(body);

        updateStats(stats, muestra);

        return card;
      }

      function renderFotosDefectos(muestra) {
        const wrap = document.createElement("div");
        wrap.className = "image-gallery";

        muestra.fotosDefectos.forEach((src, i) => {
          const thumb = document.createElement("div");
          thumb.className = "gallery-thumb";
          const img = document.createElement("img");
          img.src = src;
          img.alt = `Defecto ${i + 1}`;
          thumb.appendChild(img);
          const removeBtn = document.createElement("button");
          removeBtn.type = "button";
          removeBtn.className = "remove";
          removeBtn.setAttribute("aria-label", "Quitar foto");
          removeBtn.textContent = "×";
          removeBtn.addEventListener("click", () => {
            muestra.fotosDefectos.splice(i, 1);
            const newWrap = renderFotosDefectos(muestra);
            wrap.replaceWith(newWrap);
          });
          thumb.appendChild(removeBtn);
          wrap.appendChild(thumb);
        });

        const drop = document.createElement("label");
        drop.className = "image-drop";
        const iconBig = document.createElement("span");
        iconBig.className = "icon-big";
        iconBig.textContent = "+";
        const txt = document.createElement("span");
        txt.textContent = "Agregar foto";
        const hint = document.createElement("span");
        hint.className = "hint";
        hint.textContent = "Cámara o archivo";
        const fileInput = document.createElement("input");
        fileInput.type = "file";
        fileInput.accept = "image/*";
        fileInput.multiple = true;
        fileInput.setAttribute("capture", "environment");
        fileInput.addEventListener("change", async () => {
          const files = Array.from(fileInput.files ?? []);
          if (!supa) {
            feedbackEl.classList.remove("ok");
            feedbackEl.textContent = "No hay conexión con Supabase.";
            fileInput.value = "";
            return;
          }
          feedbackEl.classList.remove("ok");
          feedbackEl.textContent = `Subiendo ${files.length} foto${files.length === 1 ? "" : "s"}...`;
          for (const file of files) {
            try {
              const blob = await compressImage(file);
              const prefix = lote.lote;
              const url = await uploadImage(blob, "defectos", prefix);
              muestra.fotosDefectos.push(url);
            } catch (e) {
              feedbackEl.classList.remove("ok");
              feedbackEl.textContent = "No se pudo subir una imagen: " + (e?.message ?? "");
            }
          }
          if (!feedbackEl.textContent.startsWith("No se pudo")) {
            feedbackEl.textContent = "";
          }
          const newWrap = renderFotosDefectos(muestra);
          wrap.replaceWith(newWrap);
          fileInput.value = "";
        });
        drop.appendChild(iconBig);
        drop.appendChild(txt);
        drop.appendChild(hint);
        drop.appendChild(fileInput);
        wrap.appendChild(drop);

        return wrap;
      }

      function updateStats(stats, muestra) {
        const calc = calcular(muestra);
        const statusClass = `status-${calc.estado === "critico" ? "danger" : calc.estado === "alerta" ? "warn" : "ok"}`;
        const statusLabel = calc.estado === "critico" ? "Crítico" : calc.estado === "alerta" ? "Alerta" : "OK";

        stats.replaceChildren();
        stats.appendChild(textPair("Calibres", `${calc.sumCal}/${calc.total}`));
        stats.appendChild(textPair("% Defectos", formatPct(calc.defectPct)));
        stats.appendChild(textPair("% Exportable", formatPct(calc.exportablePct)));
        const status = document.createElement("span");
        status.className = `status ${statusClass}`;
        status.textContent = statusLabel;
        stats.appendChild(status);
      }

      function textPair(label, value) {
        const wrap = document.createElement("span");
        wrap.append(`${label}: `);
        const strong = document.createElement("strong");
        strong.textContent = value;
        wrap.appendChild(strong);
        return wrap;
      }

      function render() {
        muestrasList.replaceChildren();
        muestrasList.appendChild(renderMuestra(muestra));
        updateSummary();
      }

      function updateSummary() {
        const calc = calcular(muestra);
        counterEl.textContent = "";
        sumFrutosEl.textContent = calc.total.toLocaleString("es-CL");
        sumDefectosEl.textContent = formatPct(calc.defectPct);
        sumExportableEl.textContent = formatPct(calc.exportablePct);
      }

      function validar() {
        if (!lote.lote.trim()) return "Falta indicar el código del lote.";
        if (!lote.productor.trim()) return "Falta indicar el productor.";
        if (!lote.variedad.trim()) return "Falta indicar la variedad.";
        if (!String(lote.bandasCamara ?? "").trim()) {
          return "Seleccione una o más celdas en el mapa y pulse «Confirmar ubicación».";
        }
        if (asNumber(muestra.total) <= 0) return "La muestra debe tener total de frutos.";
        return "";
      }

      let guardando = false;

      async function guardar() {
        if (guardando) return;
        const err = validar();
        feedbackEl.classList.remove("ok");
        if (err) {
          feedbackEl.textContent = err;
          return;
        }
        if (!supa) {
          feedbackEl.textContent = "No hay conexión con Supabase.";
          return;
        }
        if (palletUploading) {
          feedbackEl.textContent = "Espera a que termine de subir la etiqueta del pallet.";
          return;
        }
        guardando = true;
        feedbackEl.textContent = "Guardando...";

        commitCajasKilos();

        const camaraBanda =
          lote.camaraBanda != null && Number.isFinite(Number(lote.camaraBanda)) ? Number(lote.camaraBanda) : null;
        const camaraPosicion =
          lote.camaraPosicion != null && Number.isFinite(Number(lote.camaraPosicion)) ? Number(lote.camaraPosicion) : null;
        const hasStructSlot = camaraBanda != null && camaraPosicion != null;
        const camaraAltura =
          hasStructSlot && lote.camaraAltura != null && Number.isFinite(Number(lote.camaraAltura))
            ? Number(lote.camaraAltura)
            : 1;

        const row = {
          fecha: lote.fecha || null,
          lote: lote.lote.trim(),
          productor: lote.productor.trim() || null,
          variedad: lote.variedad.trim() || null,
          procesado: false,
          camara_banda: hasStructSlot ? camaraBanda : null,
          camara_posicion: hasStructSlot ? camaraPosicion : null,
          camara_altura: camaraAltura,
          bandas_camara: String(lote.bandasCamara ?? "").trim() || null,
          cantidad_cajas: lote.cantidadCajas ?? null,
          kilos_bruto_lote: lote.kilosBrutoLote ?? null,
          kilos_neto_lote: lote.kilosNetoLote ?? null,
          etiqueta_pallet: lote.etiquetaPallet || null,
          total: asNumber(muestra.total),
          c_pre: asNumber(muestra.cPre),
          c22: asNumber(muestra.c22),
          c24: asNumber(muestra.c24),
          c26: asNumber(muestra.c26),
          c28: asNumber(muestra.c28),
          c30: asNumber(muestra.c30),
          c32: asNumber(muestra.c32),
          blanda: asNumber(muestra.blanda),
          pitting: asNumber(muestra.pitting),
          doble: asNumber(muestra.doble),
          deshidratada: asNumber(muestra.deshidratada),
          partida: asNumber(muestra.partida),
          pudricion: asNumber(muestra.pudricion),
          color_bajo: asNumber(muestra.colorBajo),
          media_luna: asNumber(muestra.mediaLuna),
          sin_pedicelo: asNumber(muestra.sinPedicelo),
          negro: asNumber(muestra.negro),
          primera: sumPrimera(muestra),
          segunda: sumSegunda(muestra),
          zumo: sumZumo(muestra),
          observaciones: String(muestra.observaciones ?? "").trim() || null,
          fotos_defectos: Array.isArray(muestra.fotosDefectos) ? muestra.fotosDefectos.slice() : []
        };

        const { error } = await supa.from(TABLE).insert(row);
        if (error) {
          guardando = false;
          feedbackEl.classList.remove("ok");
          const msg = error.message || "";
          if (error.code === "23505" || msg.includes("duplicate key") || msg.includes("camara_slot")) {
            feedbackEl.textContent =
              "Esa posición en cámara ya está ocupada. Actualice el mapa, elija otra celda y confirme de nuevo.";
            fetchCamaraOccupancy();
          } else if (msg.includes("camara_banda") || msg.includes("schema cache")) {
            feedbackEl.textContent =
              "Falta aplicar la migración SQL en Supabase (columnas camara_banda / camara_posicion / camara_altura). Revise la documentación del proyecto.";
          } else {
            feedbackEl.textContent = "No se pudo guardar: " + msg;
          }
          return;
        }
        feedbackEl.classList.add("ok");
        feedbackEl.textContent = "Guardado";
        setTimeout(() => { window.location.href = returnUrl; }, 300);
      }

      document.getElementById("save-btn").addEventListener("click", guardar);
      document.getElementById("save-btn-footer").addEventListener("click", guardar);

      renderPalletPreview();
      render();
      prefillFromLastSample();
    </script>
  </body>
</html>
