---
import { withBase } from "@/lib/basePath";

const sections = [
  {
    href: withBase("/la-torre-2026/muestras"),
    title: "Muestras",
    description: "Tabla de lotes, detalle por calibre, defectos y exportación a Excel",
    tag: null,
    icon: "chart",
    featured: true,
  },
  {
    href: withBase("/la-torre-2026/nuevo"),
    title: "Nuevo lote",
    description: "Registrar una nueva muestra de cereza en el sistema",
    tag: null,
    icon: "plus",
    featured: true,
  },
  {
    href: withBase("/la-torre-2026/bitacora"),
    title: "Bitácora del día",
    description: "Horarios, detenciones, kilos procesados y comentarios de jornada",
    tag: "Próximamente",
    icon: "journal",
    featured: false,
  },
  {
    href: withBase("/la-torre-2026/camara"),
    title: "Cámara frigorífica",
    description: "Mapa de posiciones, asignación de lotes y resumen en cámara",
    tag: "Próximamente",
    icon: "cold",
    featured: false,
  },
];
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/png" href={withBase("/img/logo-la-torre-stone-fruit.png")} />
    <title>La Torre Stone Fruits</title>
    <style is:global>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg: #fafaf9;
        --surface: #ffffff;
        --surface-glass: rgba(255, 255, 255, 0.72);
        --border: #e7e5e4;
        --ink: #1c1917;
        --muted: #78716c;
        --accent: #9f1239;
        --accent-soft: #fff1f2;
        --accent-mid: #fda4af;
        --accent-strong: #be123c;
        --shadow-sm: 0 1px 2px rgba(28, 25, 23, 0.05);
        --shadow-md: 0 12px 40px rgba(159, 18, 57, 0.08), 0 4px 12px rgba(28, 25, 23, 0.06);
        --shadow-lg: 0 24px 64px rgba(159, 18, 57, 0.12), 0 8px 24px rgba(28, 25, 23, 0.08);
        --ease: cubic-bezier(0.22, 1, 0.36, 1);
      }

      html, body {
        min-height: 100dvh;
        background: var(--bg);
        color: var(--ink);
        font-family: "Aptos", "Segoe UI", system-ui, sans-serif;
        font-size: 15px;
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      @keyframes hub-fade-up {
        from {
          opacity: 0;
          transform: translateY(16px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @keyframes hub-float {
        0%, 100% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(12px, -8px) scale(1.04); }
      }

      .hub {
        position: relative;
        min-height: 100dvh;
        overflow-x: hidden;
      }

      .hub-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background:
          radial-gradient(ellipse 80% 50% at 50% -10%, rgba(253, 164, 175, 0.35), transparent 55%),
          radial-gradient(ellipse 60% 40% at 100% 20%, rgba(190, 18, 60, 0.08), transparent 50%),
          radial-gradient(ellipse 50% 35% at 0% 80%, rgba(159, 18, 57, 0.06), transparent 45%),
          linear-gradient(180deg, #fffbfb 0%, var(--bg) 42%, #f5f5f4 100%);
      }

      .hub-bg-blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(64px);
        animation: hub-float 18s var(--ease) infinite;
      }

      .hub-bg-blob--1 {
        width: 320px;
        height: 320px;
        top: -80px;
        right: -60px;
        background: rgba(253, 164, 175, 0.45);
        animation-delay: 0s;
      }

      .hub-bg-blob--2 {
        width: 240px;
        height: 240px;
        bottom: 10%;
        left: -40px;
        background: rgba(190, 18, 60, 0.12);
        animation-delay: -6s;
        animation-duration: 22s;
      }

      .hub-shell {
        position: relative;
        z-index: 1;
        max-width: 1080px;
        margin: 0 auto;
        padding: 28px 20px 32px;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
      }

      @media (min-width: 768px) {
        .hub-shell {
          padding: 40px 32px 48px;
        }
      }

      .hub-hero {
        text-align: center;
        padding: 8px 0 36px;
        animation: hub-fade-up 0.7s var(--ease) both;
      }

      .hub-cobrand {
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        margin-bottom: 28px;
        padding: 20px 28px;
        background: var(--surface-glass);
        border: 1px solid rgba(255, 255, 255, 0.8);
        border-radius: 16px;
        box-shadow: var(--shadow-md);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
      }

      .hub-logos-pair {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 14px;
      }

      .hub-logo-latorre,
      .hub-logo-operman {
        height: 48px;
        width: auto;
        max-width: 150px;
        object-fit: contain;
        display: block;
      }

      @media (min-width: 768px) {
        .hub-logo-latorre,
        .hub-logo-operman {
          height: 56px;
          max-width: 170px;
        }
      }

      .hub-cobrand-x {
        height: 32px;
        width: auto;
        object-fit: contain;
        display: block;
        flex-shrink: 0;
        opacity: 0.85;
      }

      .hub-tagline {
        margin: 0;
        font-size: 12px;
        font-weight: 600;
        color: var(--muted);
        letter-spacing: 0.02em;
        line-height: 1.4;
        max-width: 22rem;
      }

      .hub-eyebrow {
        display: inline-block;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--accent-strong);
        background: var(--accent-soft);
        border: 1px solid rgba(190, 18, 60, 0.15);
        border-radius: 999px;
        padding: 6px 14px;
        margin-bottom: 14px;
      }

      .hub-title {
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(2rem, 6vw, 2.75rem);
        font-weight: 700;
        letter-spacing: -0.04em;
        line-height: 1.05;
        color: var(--ink);
      }

      .hub-subtitle {
        margin-top: 12px;
        font-size: 15px;
        color: var(--muted);
        max-width: 28rem;
        margin-left: auto;
        margin-right: auto;
        line-height: 1.55;
      }

      .hub-section-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 14px;
        padding-left: 2px;
      }

      .hub-main {
        flex: 1;
        animation: hub-fade-up 0.7s var(--ease) 0.12s both;
      }

      .hub-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 14px;
      }

      @media (min-width: 640px) {
        .hub-grid {
          grid-template-columns: repeat(2, 1fr);
          gap: 16px;
        }
      }

      .hub-card {
        position: relative;
        display: grid;
        grid-template-columns: auto 1fr auto;
        grid-template-rows: auto auto;
        grid-template-areas:
          "icon body arrow"
          "icon body arrow";
        align-items: center;
        gap: 4px 16px;
        padding: 20px 20px 20px 18px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        transition:
          border-color 0.25s var(--ease),
          box-shadow 0.25s var(--ease),
          transform 0.25s var(--ease);
      }

      .hub-card::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 3px;
        background: var(--accent-strong);
        transform: scaleY(0);
        transform-origin: center top;
        transition: transform 0.3s var(--ease);
        border-radius: 0 2px 2px 0;
      }

      .hub-card:hover,
      .hub-card:focus-visible {
        border-color: rgba(190, 18, 60, 0.25);
        box-shadow: var(--shadow-lg);
        transform: translateY(-3px);
      }

      .hub-card:hover::before,
      .hub-card:focus-visible::before {
        transform: scaleY(1);
      }

      .hub-card:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }

      .hub-card--soon {
        opacity: 0.92;
      }

      .hub-card--soon:hover {
        opacity: 1;
      }

      .hub-card--featured {
        border-color: rgba(190, 18, 60, 0.12);
        background: linear-gradient(135deg, #ffffff 0%, #fffafb 100%);
      }

      .hub-card-icon {
        grid-area: icon;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        border-radius: 10px;
        background: var(--accent-soft);
        color: var(--accent-strong);
        flex-shrink: 0;
        transition: background 0.25s var(--ease), transform 0.25s var(--ease);
      }

      .hub-card:hover .hub-card-icon {
        background: var(--accent-strong);
        color: #fff;
        transform: scale(1.05);
      }

      .hub-card-icon svg {
        width: 24px;
        height: 24px;
        stroke: currentColor;
        fill: none;
        stroke-width: 1.75;
        stroke-linecap: round;
        stroke-linejoin: round;
      }

      .hub-card-body {
        grid-area: body;
        min-width: 0;
      }

      .hub-card-head {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 4px;
      }

      .hub-card-title {
        font-family: Georgia, "Times New Roman", serif;
        font-size: 17px;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--ink);
        transition: color 0.2s var(--ease);
      }

      .hub-card:hover .hub-card-title {
        color: var(--accent-strong);
      }

      .hub-card-tag {
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent-strong);
        background: var(--accent-soft);
        border-radius: 999px;
        padding: 3px 9px;
      }

      .hub-card-desc {
        font-size: 13px;
        color: var(--muted);
        line-height: 1.45;
      }

      .hub-card-go {
        grid-area: arrow;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: var(--bg);
        color: var(--muted);
        transition:
          background 0.25s var(--ease),
          border-color 0.25s var(--ease),
          color 0.25s var(--ease),
          transform 0.25s var(--ease);
      }

      .hub-card-go svg {
        width: 18px;
        height: 18px;
        stroke: currentColor;
        fill: none;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
      }

      .hub-card:hover .hub-card-go {
        background: var(--accent-strong);
        border-color: var(--accent-strong);
        color: #fff;
        transform: translateX(2px);
      }

      .hub-card:nth-child(1) { animation: hub-fade-up 0.55s var(--ease) 0.18s both; }
      .hub-card:nth-child(2) { animation: hub-fade-up 0.55s var(--ease) 0.26s both; }
      .hub-card:nth-child(3) { animation: hub-fade-up 0.55s var(--ease) 0.34s both; }
      .hub-card:nth-child(4) { animation: hub-fade-up 0.55s var(--ease) 0.42s both; }

      .hub-foot {
        margin-top: 40px;
        padding-top: 20px;
        text-align: center;
        font-size: 12px;
        color: var(--muted);
        letter-spacing: 0.04em;
        animation: hub-fade-up 0.6s var(--ease) 0.5s both;
      }

      .hub-foot strong {
        color: var(--accent-strong);
        font-weight: 600;
      }

      @media (prefers-reduced-motion: reduce) {
        .hub-bg-blob,
        .hub-hero,
        .hub-main,
        .hub-card,
        .hub-foot {
          animation: none;
        }
        .hub-card:hover {
          transform: none;
        }
      }
    </style>
  </head>
  <body>
    <div class="hub">
      <div class="hub-bg" aria-hidden="true">
        <div class="hub-bg-blob hub-bg-blob--1"></div>
        <div class="hub-bg-blob hub-bg-blob--2"></div>
      </div>

      <div class="hub-shell">
        <header class="hub-hero">
          <div class="hub-cobrand" aria-label="La Torre Stone Fruits en conjunto con OPERMAN">
            <div class="hub-logos-pair">
              <img
                class="hub-logo-latorre"
                src={withBase("/img/logo-la-torre-stone-fruit.png")}
                alt="La Torre Stone Fruits"
                width="170"
                height="56"
              />
              <img
                class="hub-cobrand-x"
                src={withBase("/img/x.svg")}
                alt=""
                width="32"
                height="32"
                aria-hidden="true"
              />
              <img
                class="hub-logo-operman"
                src={withBase("/img/operman.svg")}
                alt="OPERMAN"
                width="120"
                height="56"
              />
            </div>
            <p class="hub-tagline">Muestreo de cereza · trabajo en conjunto con OPERMAN</p>
          </div>
          <p class="hub-eyebrow">Temporada 2026</p>
          <h1 class="hub-title">La Torre Stone Fruits</h1>
          <p class="hub-subtitle">Panel de control para muestreo, cámara y registro operativo de cereza.</p>
        </header>

        <main class="hub-main">
          <p class="hub-section-label">Secciones</p>
          <nav class="hub-grid" aria-label="Secciones del módulo">
            {
              sections.map((item) => (
                <a
                  class:list={[
                    "hub-card",
                    item.tag && "hub-card--soon",
                    item.featured && "hub-card--featured",
                  ]}
                  href={item.href}
                >
                  <span class="hub-card-icon" aria-hidden="true">
                    {item.icon === "chart" && (
                      <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M3 3v18h18" />
                        <path d="M7 14l4-4 4 4 5-6" />
                      </svg>
                    )}
                    {item.icon === "plus" && (
                      <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M12 5v14M5 12h14" />
                      </svg>
                    )}
                    {item.icon === "journal" && (
                      <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M4 5h16v14H4z" />
                        <path d="M8 9h8M8 13h5" />
                        <path d="M16 5v2" />
                      </svg>
                    )}
                    {item.icon === "cold" && (
                      <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M12 2v20M8 6l4-4 4 4M8 18l4 4 4-4M2 12h20" />
                      </svg>
                    )}
                  </span>
                  <div class="hub-card-body">
                    <div class="hub-card-head">
                      <h2 class="hub-card-title">{item.title}</h2>
                      {item.tag ? <span class="hub-card-tag">{item.tag}</span> : null}
                    </div>
                    <p class="hub-card-desc">{item.description}</p>
                  </div>
                  <span class="hub-card-go" aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                      <path d="M5 12h14M13 6l6 6-6 6" />
                    </svg>
                  </span>
                </a>
              ))
            }
          </nav>
        </main>

        <footer class="hub-foot">
          <strong>La Torre Stone Fruits</strong> × <strong>OPERMAN</strong> · Cereza 2026
        </footer>
      </div>
    </div>
  </body>
</html>
