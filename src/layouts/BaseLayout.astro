---
import { AppShell } from "@/components/layout";
import { stripBasePathname, withBase } from "@/lib/basePath";
import { brand } from "@/lib/brand";
import "@/styles/globals.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = "EMBARQUES - Logística y Comercio Exterior", description = "Logística y Comercio Exterior" } = Astro.props;
const pathname = stripBasePathname(Astro.url.pathname);
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={withBase("/logoasli.png")} />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script
      type="module"
      src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"
    ></script>
    <style is:global>
      vercel-live-feedback, #vercel-live-feedback, .__vercel_live_token,
      [data-vercel-toolbar], vercel-toolbar { display: none !important; }
    </style>
  </head>
  <body class="h-screen overflow-hidden font-sans antialiased" style="--font-open-sans: 'Open Sans', system-ui, sans-serif">
    <!-- Mismo lenguaje visual que ModuleRouteLoader (hasta que hidrata AppShell). -->
    <div
      id="app-shell-loading"
      class="fixed inset-0 z-[2147483647] flex flex-col items-center justify-center px-4 py-8 text-center antialiased bg-gradient-to-b from-neutral-50 via-neutral-100 to-neutral-100/95"
      aria-busy="true"
      aria-live="polite"
    >
      <div
        class="pointer-events-none absolute inset-0 opacity-[0.35]"
        aria-hidden="true"
        style="background-image: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(29, 78, 216, 0.14), transparent), radial-gradient(ellipse 60% 40% at 100% 100%, rgba(13, 148, 136, 0.08), transparent);"
      />
      <div
        class="relative z-10 flex w-full max-w-sm flex-col items-center gap-6 rounded-2xl border border-neutral-200/90 bg-white/85 px-8 py-10 shadow-[0_24px_60px_-16px_rgba(29,78,216,0.18)] backdrop-blur-sm sm:py-12"
      >
        <div class="flex flex-col items-center gap-5">
          <img
            src={brand.logo}
            alt={brand.companyShort}
            width="200"
            height="56"
            class="h-12 w-auto max-w-[min(220px,85vw)] object-contain object-center drop-shadow-sm animate-module-loader-ship sm:h-14"
            decoding="async"
            fetchpriority="high"
          />
          <div class="flex h-8 w-full max-w-[7rem] items-end justify-center gap-1.5" aria-hidden="true">
            <span
              class="animate-module-loader-bar h-[1.35rem] w-2 rounded-sm bg-brand-blue"
              style="animation-delay: 0ms"
            ></span>
            <span
              class="animate-module-loader-bar h-[1.35rem] w-2 rounded-sm bg-brand-teal"
              style="animation-delay: 140ms"
            ></span>
            <span
              class="animate-module-loader-bar h-[1.35rem] w-2 rounded-sm bg-brand-blue"
              style="animation-delay: 280ms"
            ></span>
          </div>
        </div>
        <p class="m-0 px-2 text-center text-sm font-medium tracking-tight text-neutral-600">
          Preparando interfaz…
        </p>
        <div class="h-1 w-full max-w-[11rem] overflow-hidden rounded-full bg-neutral-200/90" aria-hidden="true">
          <div
            class="animate-module-loader-rail h-full w-2/5 rounded-full bg-gradient-to-r from-brand-blue via-brand-teal to-brand-blue bg-[length:200%_100%]"
          >
          </div>
        </div>
      </div>
      <p
        id="app-shell-loading-hint"
        class="relative z-10 mt-6 hidden max-w-sm text-xs leading-snug text-neutral-500"
        style="display: none"
      >
        Si esto no desaparece, el JavaScript falló en este dispositivo. En Chrome (Android): USB → Depurar en el PC
        (chrome://inspect). Revisa la consola y la pestaña Red por URLs en rojo (a veces fallan rutas con espacios en la carpeta del proyecto).
      </p>
    </div>
    <AppShell client:load pathname={pathname}>
      <slot />
    </AppShell>
    <script is:inline>
      (function () {
        var hint = document.getElementById("app-shell-loading-hint");
        var t = setTimeout(function () {
          if (hint) {
            hint.classList.remove("hidden");
            hint.style.display = "block";
          }
        }, 12000);
        function bind() {
          var island = document.querySelector("astro-island");
          if (!island) {
            requestAnimationFrame(bind);
            return;
          }
          island.addEventListener("astro:hydrate", function () {
            clearTimeout(t);
            var el = document.getElementById("app-shell-loading");
            if (el) el.remove();
          });
        }
        bind();
      })();
    </script>
  </body>
</html>
