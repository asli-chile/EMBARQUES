# Web2 (Next.js) — copiar a .env.local para desarrollo o definir en Vercel → Environment Variables
#
# URL pública del sitio marketing (este despliegue), sin barra final.
NEXT_PUBLIC_ERP_URL=https://asli.cl
#
# URL completa del sistema Embarques (Astro), con prefijo /embarques.
# Obligatorio si Embarques está en otro dominio o subdominio que web2.
# Ejemplos:
#   https://embarques-xxx.vercel.app/embarques
#   https://app.asli.cl/embarques
# Si se omite, se usa NEXT_PUBLIC_ERP_URL + "/embarques".
# NEXT_PUBLIC_EMBARQUES_BASE_URL=https://asli.cl/embarques
