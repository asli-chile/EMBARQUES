# Web2 (Next.js) — copiar a .env.local o definir en Vercel → Environment Variables
#
# URL del backend Embarques (Astro) en Vercel, con prefijo /embarques.
# Ejemplo: https://embarques-teal.vercel.app/embarques
#
# NUNCA pongas aquí https://asli.cl/embarques — el proxy de Next se rompe (404).
# En el proyecto Embarques (Astro) sí puedes usar PUBLIC_SITE_URL=https://asli.cl para enlaces.
#
# NEXT_PUBLIC_EMBARQUES_BASE_URL=https://embarques-teal.vercel.app/embarques
#
# API key de Resend para envío automático del formulario de contacto.
# Obtener en: https://resend.com → API Keys
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
